program test.aleo {
    function main() {
        assert_eq(a, b);
        assert_eq(
            some_very_long_variable_name_that_is_really_long,
            another_very_long_variable_name_for_comparison
        );
        assert_neq(x, y);
        assert_neq(
            first_extremely_long_identifier_name,
            second_extremely_long_identifier_name_for_testing
        );
    }
}
