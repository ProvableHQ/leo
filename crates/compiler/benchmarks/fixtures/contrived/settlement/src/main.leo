    fn compute_st_000(seed: u64) -> u64 {
        let st00_v0 = seed + 0u64;
        let st00_v1 = seed + 1u64;
        let st00_v2 = seed + 2u64;
        let st00_v3 = seed + 3u64;
        let st00_v4 = seed + 4u64;
        let st00_v5 = seed + 5u64;
