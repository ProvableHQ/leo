program main.aleo {
    fn exercise() {
        let rp1 = std::commit::bhp512::commit_bool_to_address(true, 1scalar);
        assert_eq(rp1, rp1);
        let rp2 = std::commit::bhp512::commit_bool_to_field(true, 1scalar);
        assert_eq(rp2, rp2);
        let rp3 = std::commit::bhp512::commit_bool_to_group(true, 1scalar);
        assert_eq(rp3, rp3);
        let rp4 = std::commit::bhp512::commit_u8_to_address(1u8, 1scalar);
        assert_eq(rp4, rp4);
        let rp5 = std::commit::bhp512::commit_u8_to_field(1u8, 1scalar);
        assert_eq(rp5, rp5);
        let rp6 = std::commit::bhp512::commit_u8_to_group(1u8, 1scalar);
        assert_eq(rp6, rp6);
        let rp7 = std::commit::bhp512::commit_u16_to_address(1u16, 1scalar);
        assert_eq(rp7, rp7);
        let rp8 = std::commit::bhp512::commit_u16_to_field(1u16, 1scalar);
        assert_eq(rp8, rp8);
        let rp9 = std::commit::bhp512::commit_u16_to_group(1u16, 1scalar);
        assert_eq(rp9, rp9);
        let rp10 = std::commit::bhp512::commit_u32_to_address(1u32, 1scalar);
        assert_eq(rp10, rp10);
        let rp11 = std::commit::bhp512::commit_u32_to_field(1u32, 1scalar);
        assert_eq(rp11, rp11);
        let rp12 = std::commit::bhp512::commit_u32_to_group(1u32, 1scalar);
        assert_eq(rp12, rp12);
        let rp13 = std::commit::bhp512::commit_u64_to_address(1u64, 1scalar);
        assert_eq(rp13, rp13);
        let rp14 = std::commit::bhp512::commit_u64_to_field(1u64, 1scalar);
        assert_eq(rp14, rp14);
        let rp15 = std::commit::bhp512::commit_u64_to_group(1u64, 1scalar);
        assert_eq(rp15, rp15);
        let rp16 = std::commit::bhp512::commit_u128_to_address(1u128, 1scalar);
        assert_eq(rp16, rp16);
        let rp17 = std::commit::bhp512::commit_u128_to_field(1u128, 1scalar);
        assert_eq(rp17, rp17);
        let rp18 = std::commit::bhp512::commit_u128_to_group(1u128, 1scalar);
        assert_eq(rp18, rp18);
        let rp19 = std::commit::bhp512::commit_i8_to_address(1i8, 1scalar);
        assert_eq(rp19, rp19);
        let rp20 = std::commit::bhp512::commit_i8_to_field(1i8, 1scalar);
        assert_eq(rp20, rp20);
        let rp21 = std::commit::bhp512::commit_i8_to_group(1i8, 1scalar);
        assert_eq(rp21, rp21);
        let rp22 = std::commit::bhp512::commit_i16_to_address(1i16, 1scalar);
        assert_eq(rp22, rp22);
        let rp23 = std::commit::bhp512::commit_i16_to_field(1i16, 1scalar);
        assert_eq(rp23, rp23);
        let rp24 = std::commit::bhp512::commit_i16_to_group(1i16, 1scalar);
        assert_eq(rp24, rp24);
        let rp25 = std::commit::bhp512::commit_i32_to_address(1i32, 1scalar);
        assert_eq(rp25, rp25);
        let rp26 = std::commit::bhp512::commit_i32_to_field(1i32, 1scalar);
        assert_eq(rp26, rp26);
        let rp27 = std::commit::bhp512::commit_i32_to_group(1i32, 1scalar);
        assert_eq(rp27, rp27);
        let rp28 = std::commit::bhp512::commit_i64_to_address(1i64, 1scalar);
        assert_eq(rp28, rp28);
        let rp29 = std::commit::bhp512::commit_i64_to_field(1i64, 1scalar);
        assert_eq(rp29, rp29);
        let rp30 = std::commit::bhp512::commit_i64_to_group(1i64, 1scalar);
        assert_eq(rp30, rp30);
        let rp31 = std::commit::bhp512::commit_i128_to_address(1i128, 1scalar);
        assert_eq(rp31, rp31);
        let rp32 = std::commit::bhp512::commit_i128_to_field(1i128, 1scalar);
        assert_eq(rp32, rp32);
        let rp33 = std::commit::bhp512::commit_i128_to_group(1i128, 1scalar);
        assert_eq(rp33, rp33);
        let rp34 = std::commit::bhp512::commit_field_to_address(1field, 1scalar);
        assert_eq(rp34, rp34);
        let rp35 = std::commit::bhp512::commit_field_to_field(1field, 1scalar);
        assert_eq(rp35, rp35);
        let rp36 = std::commit::bhp512::commit_field_to_group(1field, 1scalar);
        assert_eq(rp36, rp36);
        let rp37 = std::commit::bhp512::commit_group_to_address(0group, 1scalar);
        assert_eq(rp37, rp37);
        let rp38 = std::commit::bhp512::commit_group_to_field(0group, 1scalar);
        assert_eq(rp38, rp38);
        let rp39 = std::commit::bhp512::commit_group_to_group(0group, 1scalar);
        assert_eq(rp39, rp39);
        let rp40 = std::commit::bhp512::commit_scalar_to_address(1scalar, 1scalar);
        assert_eq(rp40, rp40);
        let rp41 = std::commit::bhp512::commit_scalar_to_field(1scalar, 1scalar);
        assert_eq(rp41, rp41);
        let rp42 = std::commit::bhp512::commit_scalar_to_group(1scalar, 1scalar);
        assert_eq(rp42, rp42);
        let rp43 = std::commit::bhp512::commit_address_to_address(aleo1az8p9vlllyqwtj0c2g9svkd0e5v0p3zzdflwwrpa7kpe8xrfxgfqqpru7m, 1scalar);
        assert_eq(rp43, rp43);
        let rp44 = std::commit::bhp512::commit_address_to_field(aleo1az8p9vlllyqwtj0c2g9svkd0e5v0p3zzdflwwrpa7kpe8xrfxgfqqpru7m, 1scalar);
        assert_eq(rp44, rp44);
        let rp45 = std::commit::bhp512::commit_address_to_group(aleo1az8p9vlllyqwtj0c2g9svkd0e5v0p3zzdflwwrpa7kpe8xrfxgfqqpru7m, 1scalar);
        assert_eq(rp45, rp45);
        return;
    }

    @noupgrade
    constructor() {}
}
