        let rp187 = std::hash::pedersen64::hash_i32_to_u8_raw(1i32);
        assert_eq(rp187, rp187);
        let rp188 = std::hash::pedersen64::hash_i32_to_u16_raw(1i32);
        assert_eq(rp188, rp188);
        let rp189 = std::hash::pedersen64::hash_i32_to_u32_raw(1i32);
        assert_eq(rp189, rp189);
