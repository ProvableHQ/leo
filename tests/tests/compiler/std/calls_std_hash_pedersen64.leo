        assert_eq(rp190, rp190);
        let rp191 = std::hash::pedersen64::hash_i32_to_u128_raw(1i32);
        assert_eq(rp191, rp191);
        let rp192 = std::hash::pedersen64::hash_i32_to_i8_raw(1i32);
        assert_eq(rp192, rp192);
        let rp193 = std::hash::pedersen64::hash_i32_to_i16_raw(1i32);
        assert_eq(rp193, rp193);
        let rp194 = std::hash::pedersen64::hash_i32_to_i32_raw(1i32);
        assert_eq(rp194, rp194);
        let rp195 = std::hash::pedersen64::hash_i32_to_i64_raw(1i32);
        assert_eq(rp195, rp195);
        let rp196 = std::hash::pedersen64::hash_i32_to_i128_raw(1i32);
        assert_eq(rp196, rp196);
