#!/usr/bin/env bash

# Test that --network-retries is accepted by all commands that support it.
# We only check --help output; no network calls are made.

LEO_BIN=${1}

for cmd in build run execute deploy upgrade query synthesize; do
    if ${LEO_BIN} --disable-update-check "${cmd}" --help 2>&1 | grep -qF -- '--network-retries'; then
        echo "${cmd}: --network-retries OK"
    else
        echo "${cmd}: --network-retries MISSING"
        exit 1
    fi
done
