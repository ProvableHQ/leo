#!/usr/bin/env bash

# Tests that `leo build` on a library primary runs type checking and reports
# type errors inside library function bodies.

LEO_BIN=${1}

cd my_lib || exit 1

echo "--- leo build (should fail: type error in library) ---" | tee /dev/stderr
${LEO_BIN} --disable-update-check build
echo "build exit code: $?"
