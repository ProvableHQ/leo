#!/usr/bin/env bash

# Tests that `leo build` on a program implementing local interfaces emits
# per-interface ABI files in build/foo/interfaces/ and populates `implements`
# in the program ABI.

LEO_BIN=${1}

echo "--- leo build (program with local interfaces) ---" | tee /dev/stderr
${LEO_BIN} --disable-update-check build
echo "build exit code: $?"

echo "--- program ABI ---" | tee /dev/stderr
cat build/foo/abi.json
echo

echo "--- Adder interface ABI ---" | tee /dev/stderr
cat build/foo/interfaces/Adder.json
echo

echo "--- Doubler interface ABI ---" | tee /dev/stderr
cat build/foo/interfaces/Doubler.json
