module grp {
    export fn generator() -> group {
        return _group_gen();
    }
    export fn aleo_generator() -> group {
        return _aleo_generator();
    }
    export fn aleo_generator_powers() -> [group; 251] {
        return _aleo_generator_powers();
    }
    export fn to_x_coordinate(g: group) -> field {
        return g.to_x_coordinate();
    }
    export fn to_y_coordinate(g: group) -> field {
        return g.to_y_coordinate();
    }
}

module ctx {
    export fn addr() -> address {
        return _self_address();
    }
    @_caller_annotation
    export fn caller() -> address {
        return _self_caller();
    }
    export fn signer() -> address {
        return _self_signer();
    }
    export fn id() -> address {
        return _self_id();
    }
    export final fn checksum() -> [u8; 32] {
        return _self_checksum();
    }
    export final fn edition() -> u16 {
        return _self_edition();
    }
    export final fn program_owner() -> address {
        return _self_program_owner();
    }
    @_onchain_context
    export fn block_height() -> u32 {
        return _block_height();
    }
    export final fn block_timestamp() -> i64 {
        return _block_timestamp();
    }
    @_onchain_context
    export fn network_id() -> u16 {
        return _network_id();
    }
}

module prog {
    @_program_id_arg
    export final fn checksum::[PROG: address]() -> [u8; 32] {
        return _program_checksum(PROG);
    }
    @_program_id_arg
    export final fn edition::[PROG: address]() -> u16 {
        return _program_edition(PROG);
    }
    @_program_id_arg
    export final fn program_owner::[PROG: address]() -> address {
        return _program_owner(PROG);
    }
    @_program_id_arg
    @_callable_function_arg
    export final fn function_checksum::[PROG: address, FN_NAME: identifier]() -> [u8; 32] {
        return _function_checksum(PROG, FN_NAME);
    }
}

}

library ast_library {
    export fn scale(x: u32, factor: u32) -> u32 {
        return x * factor;
    }
module helpers {
    export const UNIT: u32 = 1u32;
    export fn increment(x: u32) -> u32 {
        return x + UNIT;
    }
}

}
