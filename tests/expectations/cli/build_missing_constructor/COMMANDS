#!/usr/bin/env bash
set -euo pipefail

LEO_BIN=${1}
TMP_DIR=$(mktemp -d)
trap 'rm -rf "${TMP_DIR}"' EXIT

if ${LEO_BIN} --disable-update-check build >"${TMP_DIR}/stdout" 2>"${TMP_DIR}/stderr"; then
    echo "leo build unexpectedly succeeded"
    exit 1
fi

grep -q "must declare a constructor" "${TMP_DIR}/stderr"
grep -q 'Add a constructor such as `@noupgrade constructor() {}` inside the `program` block.' "${TMP_DIR}/stderr"

rm -rf build
echo "missing constructor rejected"
