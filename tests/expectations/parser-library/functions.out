library test_lib {
    fn simple(a: u32, b: u32) -> u32 {
        return a + b;
    }
}


library test_lib {
    fn no_args() -> u32 {
        return 42u32;
    }
}


library test_lib {
    fn generic::[N: u32](x: u32) -> u32 {
        return x * N;
    }
}


library test_lib {
    fn multi_generic::[A: u32, B: u32](x: u32) -> u32 {
        return x * A + B;
    }
}


library test_lib {
    fn calls_other(x: u32) -> u32 {
        return simple(x, x);
    }
}


