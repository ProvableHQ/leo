program test.aleo {
    record Token {
        owner: address,
        amount: u64,
    }
    fn mint(owner: address) -> test.aleo::Token {
        return test.aleo::Token { owner: owner, amount: 0u64 };
    }
    fn transfer(t: test.aleo::Token, to: address) -> test.aleo::Token {
        return test.aleo::Token { owner: to, amount: t.amount };
    }
    fn burn(t: test.aleo::Token) -> address {
        return t.owner;
    }
}

