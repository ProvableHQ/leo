program test.aleo {
    @noupgrade
    async constructor() {
    }
    fn main(a: u32, b: u32) -> u32 {
        let first: u32 = test.aleo::square(a);
        let second: u32 = test.aleo::square(b);
        return first + second;
    }
}
    export fn square(x: u32) -> u32 {
        return x * x;
    }

