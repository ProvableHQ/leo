program test.aleo {
    struct u32? {
        is_some: bool,
        val: u32,
    }
    fn assign_optional_from_unwrap() -> u32 {
        let a: test.aleo::u32? = test.aleo::u32? { is_some: true, val: 5u32 };
        let $opt$0 = a;
        assert($opt$0.is_some);
        let b: test.aleo::u32? = test.aleo::u32? { is_some: true, val: $opt$0.val };
        let $opt$1 = a;
        assert($opt$1.is_some);
        let c: test.aleo::u32? = test.aleo::u32? { is_some: true, val: $opt$1.val + 7u32 };
        let $opt$2 = a;
        let d: test.aleo::u32? = test.aleo::u32? { is_some: true, val: $opt$2.is_some ? $opt$2.val : 0 };
        let $opt$3 = b;
        assert($opt$3.is_some);
        let $opt$4 = c;
        assert($opt$4.is_some);
        let $opt$5 = d;
        assert($opt$5.is_some);
        return $opt$3.val + $opt$4.val + $opt$5.val;
    }
}

