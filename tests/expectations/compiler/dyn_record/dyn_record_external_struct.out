program token.aleo;

struct Metadata:
    amount as u64;

record Token:
    owner as address.private;
    meta as Metadata.private;

function mint:
    input r0 as Metadata.private;
    cast self.signer r0 into r1 as Token.record;
    output r1 as Token.record;

constructor:
    assert.eq edition 0u16;
// --- Next Program --- //
import token.aleo;
program test.aleo;

function main:
    input r0 as token.aleo/Token.record;
    cast r0 into r1 as dynamic.record;
    get.record.dynamic r1.meta into r2 as token.aleo/Metadata;
    output r2.amount as u64.private;
