program ext.aleo;

function from_ext:
    output 7u32 as u32.private;

constructor:
    assert.eq edition 0u16;
// --- Next Program --- //
import ext.aleo;
program test.aleo;

record Token:
    owner as address.private;
    amount as u64.private;

struct Holder:
    shorthand_val as u32;

mapping balances:
    key as address.public;
    value as u128.public;

function main:
    input r0 as u32.public;
    input r1 as u32.public;
    add r0 99u32 into r2;
    add r2 1u32 into r3;
    add r0 1u32 into r4;
    add r3 r4 into r5;
    call ext.aleo/from_ext into r6;
    add r5 r6 into r7;
    output r7 as u32.private;

constructor:
    assert.eq edition 0u16;
