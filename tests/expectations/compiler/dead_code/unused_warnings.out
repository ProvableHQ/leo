// --- Next Program --- //
import ext.aleo;
program test.aleo;

record Token:
    owner as address.private;
    amount as u64.private;

struct UsedStruct:
    a as u32;

mapping balances:
    key as address.public;
    value as u128.public;

function main:
    input r0 as u32.private;
    add r0 2u32 into r1;
    add r1 r0 into r2;
    add r2 r0 into r3;
    add r3 r0 into r4;
    add r0 1u32 into r5;
    add r4 r5 into r6;
    output r6 as u32.private;

constructor:
    assert.eq edition 0u16;
