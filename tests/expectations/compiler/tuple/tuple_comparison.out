program tuple_eq_flat_stress.aleo;

struct S:
    a as u32;
    b as u32;

closure make_pair:
    input r0 as u32;
    input r1 as u32;
    assert.eq true true;
    output r0 as u32;
    output r1 as u32;

closure make_triple:
    input r0 as u32;
    input r1 as u32;
    input r2 as u32;
    assert.eq true true;
    output r0 as u32;
    output r1 as u32;
    output r2 as u32;

function test_all:
    assert.eq 1u32 1u32;
    assert.eq 2u32 2u32;
    assert.neq 1u32 1u32;
    assert.neq 2u32 3u32;
    assert.eq 5u32 5u32;
    assert.eq 6u32 6u32;
    assert.eq 7u32 7u32;
    assert.neq 5u32 5u32;
    assert.neq 6u32 9u32;
    assert.neq 7u32 7u32;
    assert.eq true true;
    assert.eq true true;
    assert.eq true true;
    assert.eq true true;
    call make_pair 10u32 20u32 into r0 r1;
    call make_pair 10u32 30u32 into r2 r3;
    assert.eq r0 r0;
    assert.eq r1 r1;
    assert.neq r0 r2;
    assert.neq r1 r3;
    is.eq r0 r2 into r4;
    is.eq r1 r3 into r5;
    and r4 r5 into r6;
    assert.eq true true;
    is.eq r6 false into r7;
    assert.eq r7 true;
    call make_triple 1u32 2u32 3u32 into r8 r9 r10;
    call make_triple 1u32 4u32 3u32 into r11 r12 r13;
    assert.eq r8 r8;
    assert.eq r9 r9;
    assert.eq r10 r10;
    assert.neq r8 r11;
    assert.neq r9 r12;
    assert.neq r10 r13;
    is.eq r8 r11 into r14;
    is.eq r9 r12 into r15;
    and r14 r15 into r16;
    is.eq r10 r13 into r17;
    and r16 r17 into r18;
    is.eq r18 false into r19;
    assert.eq r19 true;
    assert.eq true true;
    assert.eq true true;
    assert.eq true true;
    assert.eq true true;
    assert.eq 9u32 9u32;
    assert.eq 8u32 8u32;
    assert.neq 9u32 9u32;
    assert.neq 8u32 7u32;
    assert.eq 1u32 1u32;
    assert.eq 2u32 2u32;
    assert.eq 3u32 3u32;
    assert.eq 4u32 4u32;
    assert.neq 1u32 1u32;
    assert.neq 2u32 2u32;
    assert.neq 3u32 0u32;
    assert.neq 4u32 4u32;
    assert.eq true true;
    assert.eq true true;
    assert.eq true true;
    assert.eq true true;
    assert.eq true true;
    assert.eq true true;
    assert.eq true true;
    assert.eq true true;
    assert.neq 42u32 42u32;
    assert.neq 99u32 42u32;
    assert.eq 1u32 1u32;
    assert.eq 2u32 2u32;
    assert.eq 30u32 30u32;
    assert.eq 40u32 40u32;
    assert.eq 5u32 5u32;
    assert.eq 6u32 6u32;
    assert.eq 11u32 11u32;
    assert.eq 22u32 22u32;
