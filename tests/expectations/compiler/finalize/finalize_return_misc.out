program test.aleo;

mapping account:
    key as address.public;
    value as u64.public;

mapping flags:
    key as u8.public;
    value as boolean.public;

function update:
    input r0 as address.public;
    input r1 as u64.public;
    async update r0 r1 into r2;
    output r2 as test.aleo/update.future;

finalize update:
    input r0 as address.public;
    input r1 as u64.public;
    get.or_use account[r0] 0u64 into r2;
    add r2 r1 into r3;
    gt r3 1000u64 into r4;
    set r3 into account[r0];
    set r4 into flags[0u8];
    get.or_use account[r0] 0u64 into r5;
    add r5 1u64 into r6;
    set r6 into account[r0];

constructor:
    set 1000000u64 into account[test.aleo];
