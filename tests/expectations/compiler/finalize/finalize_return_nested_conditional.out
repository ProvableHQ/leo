program test.aleo;

mapping tiers:
    key as address.public;
    value as u8.public;

mapping audit:
    key as u8.public;
    value as u8.public;

function classify:
    input r0 as address.public;
    input r1 as u64.public;
    async classify r1 r0 into r2;
    output r2 as test.aleo/classify.future;

finalize classify:
    input r0 as u64.public;
    input r1 as address.public;
    gte r0 1000u64 into r2;
    branch.eq r2 false to end_then_0_0;
    gte r0 1000000u64 into r3;
    branch.eq r3 false to end_then_1_2;
    set 3u8 into tiers[r1];
    set 3u8 into audit[3u8];
    branch.eq true true to end_otherwise_1_3;
    position end_then_1_2;
    set 2u8 into tiers[r1];
    set 2u8 into audit[2u8];
    position end_otherwise_1_3;
    branch.eq true true to end_otherwise_0_1;
    position end_then_0_0;
    gte r0 10u64 into r4;
    branch.eq r4 false to end_then_1_4;
    set 1u8 into tiers[r1];
    set 1u8 into audit[1u8];
    branch.eq true true to end_otherwise_1_5;
    position end_then_1_4;
    set 0u8 into tiers[r1];
    set 0u8 into audit[0u8];
    position end_otherwise_1_5;
    position end_otherwise_0_1;

constructor:
    assert.eq edition 0u16;
