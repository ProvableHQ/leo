program test.aleo;

mapping store:
    key as u32.public;
    value as u32.public;

function set_val:
    input r0 as u32.private;
    input r1 as u32.private;
    async set_val r0 r1 into r2;
    output true as boolean.private;
    output r2 as test.aleo/set_val.future;

finalize set_val:
    input r0 as u32.public;
    input r1 as u32.public;
    set r1 into store[r0];

function main:
    input r0 as field.private;
    input r1 as u32.private;
    input r2 as u32.private;
    input r3 as u32.private;
    call.dynamic r0 'aleo' 'set_val' with r1 r2 (as u32.private u32.private) into r4 r5 (as boolean.private dynamic.future);
    async main r5 r3 into r6;
    output r4 as boolean.private;
    output r6 as test.aleo/main.future;

finalize main:
    input r0 as dynamic.future;
    input r1 as u32.public;
    await r0;
    gt r1 0u32 into r2;
    assert.eq r2 true;
