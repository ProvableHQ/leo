program test.aleo;

function consume:
    input r0 as [u8; 4u32].private;
    cast r0[0u32] into r1 as u32;
    output r1 as u32.private;

function driver:
    input r0 as field.private;
    input r1 as u8.public;
    input r2 as u8.public;
    add r1 r2 into r3;
    cast r3 r3 r3 r3 into r4 as [u8; 4u32];
    call.dynamic r0 'aleo' 'consume' with r4 (as [u8; 4u32].private) into r5 (as u32.private);
    output r5 as u32.private;

constructor:
    assert.eq edition 0u16;
