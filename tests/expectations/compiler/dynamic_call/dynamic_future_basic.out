program test.aleo;

mapping counts:
    key as u32.public;
    value as u32.public;

function greet:
    input r0 as u32.private;
    async greet r0 into r1;
    output r0 as u32.private;
    output r1 as test.aleo/greet.future;

finalize greet:
    input r0 as u32.public;
    set r0 into counts[r0];

function main:
    input r0 as field.private;
    input r1 as u32.private;
    call.dynamic r0 'aleo' 'greet' with r1 (as u32.private) into r2 r3 (as u32.private dynamic.future);
    async main r3 into r4;
    output r2 as u32.private;
    output r4 as test.aleo/main.future;

finalize main:
    input r0 as dynamic.future;
    await r0;
