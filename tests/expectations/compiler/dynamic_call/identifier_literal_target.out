program test.aleo;

function sum:
    input r0 as u32.private;
    input r1 as u32.private;
    add r0 r1 into r2;
    output r2 as u32.private;

function main:
    input r0 as u32.private;
    input r1 as u32.private;
    call.dynamic 'foo' 'aleo' 'sum' with r0 r1 (as u32.private u32.private) into r2 (as u32.private);
    output r2 as u32.private;
