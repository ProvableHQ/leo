program test.aleo;

struct Inner:
    a as u32;
    b as u32;

struct Outer:
    inner as Inner;
    tag as u32;

function main:
    input r0 as Outer.private;
    input r1 as u32.private;
    add r1 r0.inner.b into r2;
    add r2 r0.tag into r3;
    output r3 as u32.private;

constructor:
    assert.eq edition 0u16;
