import optprod.aleo;
program optconsumer.aleo;

function build:
    input r0 as u32.private;
    output r0 as u32.private;

function build_from_condition:
    input r0 as boolean.private;
    input r1 as u32.private;
    input r2 as u32.private;
    ternary r0 r1 0u32 into r3;
    cast r0 r3 into r4 as optprod.aleo/Optional__JzunLORyB8U;
    ternary r4.is_some r4.val r2 into r5;
    output r5 as u32.private;

constructor:
    assert.eq edition 0u16;
