import base.aleo;
program middle.aleo;

function wrap_data:
    input r0 as u32.private;
    input r1 as u32.private;
    cast r0 r1 into r2 as base.aleo/Data;
    output r2 as base.aleo/Data.private;

constructor:
    assert.eq edition 0u16;
// --- Next Program --- //
import base.aleo;
import middle.aleo;
program top.aleo;

function main:
    input r0 as u32.private;
    input r1 as u32.private;
    call middle.aleo/wrap_data r0 r1 into r2;
    output r2 as base.aleo/Data.private;
