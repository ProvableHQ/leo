import child.aleo;
program parent.aleo;

function combine:
    input r0 as child.aleo/Point__EQrYLk3V7pa.private;
    input r1 as child.aleo/Scaled__G8MwLTGHMVv.private;
    add r0.x r0.y into r2;
    add r2 r1.origin into r3;
    add r3 r1.factor into r4;
    output r4 as u32.private;

function segment_length:
    input r0 as child.aleo/Segment__14CrFljlunD.private;
    sub r0.end.x r0.start.x into r1;
    sub r0.end.y r0.start.y into r2;
    add r1 r2 into r3;
    output r3 as u32.private;

function make_and_measure:
    input r0 as u32.private;
    input r1 as u32.private;
    input r2 as u32.private;
    input r3 as u32.private;
    cast r0 r1 into r4 as child.aleo/Point__EQrYLk3V7pa;
    cast r2 r3 into r5 as child.aleo/Point__EQrYLk3V7pa;
    sub r5.x r4.x into r6;
    sub r5.y r4.y into r7;
    add r6 r7 into r8;
    output r8 as u32.private;

function full_combo:
    input r0 as child.aleo/Segment__14CrFljlunD.private;
    input r1 as child.aleo/Scaled__G8MwLTGHMVv.private;
    sub r0.end.x r0.start.x into r2;
    sub r0.end.y r0.start.y into r3;
    add r2 r3 into r4;
    mul r4 r1.factor into r5;
    add r5 r1.origin into r6;
    output r6 as u32.private;

constructor:
    assert.eq edition 0u16;


