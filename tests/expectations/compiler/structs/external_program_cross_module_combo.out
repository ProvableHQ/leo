    output r0 as Point__EQrYLk3V7pa.private;

function make_segment:
    input r0 as u32.private;
    input r1 as u32.private;
    input r2 as u32.private;
    input r3 as u32.private;
    cast r0 r1 into r4 as Point__EQrYLk3V7pa;
    cast r2 r3 into r5 as Point__EQrYLk3V7pa;
