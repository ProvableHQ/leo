program test.aleo;

function maybe_query:
    input r0 as field.private;
    input r1 as address.private;
    input r2 as boolean.private;
    async maybe_query r0 r1 r2 into r3;
    output r3 as test.aleo/maybe_query.future;

finalize maybe_query:
    input r0 as field.public;
    input r1 as address.public;
    input r2 as boolean.public;
    branch.eq r2 false to end_then_0_0;
    get.dynamic r0 'aleo' 'balances'[r1] into r3 as u64;
    contains.dynamic r0 'aleo' 'balances'[r1] into r4;
    get.or_use.dynamic r0 'aleo' 'balances'[r1] 0u64 into r5 as u64;
    branch.eq true true to end_otherwise_0_1;
    position end_then_0_0;
    position end_otherwise_0_1;
