program test.aleo;

function check:
    input r0 as field.private;
    input r1 as address.private;
    async check r0 r1 into r2;
    output r2 as test.aleo/check.future;

finalize check:
    input r0 as field.public;
    input r1 as address.public;
    get.or_use.dynamic r0 'aleo' 'balances'[r1] 0u64 into r2 as u64;
    get.or_use.dynamic r0 'aleo' 'stakes'[r1] 0u64 into r3 as u64;
    add r2 r3 into r4;
    gte r4 0u64 into r5;
    assert.eq r5 true;
