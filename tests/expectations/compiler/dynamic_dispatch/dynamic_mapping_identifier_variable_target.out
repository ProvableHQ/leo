program test.aleo;

function lookup:
    input r0 as identifier.private;
    input r1 as address.private;
    async lookup r0 r1 into r2;
    output r2 as test.aleo/lookup.future;

finalize lookup:
    input r0 as identifier.public;
    input r1 as address.public;
    get.dynamic r0 'aleo' 'balances'[r1] into r2 as u64;

constructor:
    assert.eq edition 0u16;
