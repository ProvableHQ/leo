program test.aleo;

mapping balances:
    key as address.public;
    value as u64.public;

function get_balance_or_default:
    input r0 as address.private;
    async get_balance_or_default r0 into r1;
    output r1 as test.aleo/get_balance_or_default.future;

finalize get_balance_or_default:
    input r0 as address.public;
    get.or_use.dynamic 'some_program' 'aleo' 'balances'[r0] 0u64 into r1 as u64;
    assert.eq r1 0u64;
