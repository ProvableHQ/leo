program test.aleo;

mapping result:
    key as address.public;
    value as u64.public;

function get_or_default:
    input r0 as identifier.private;
    input r1 as identifier.private;
    input r2 as identifier.private;
    input r3 as address.private;
    async get_or_default r0 r1 r2 r3 into r4;
    output r4 as test.aleo/get_or_default.future;

finalize get_or_default:
    input r0 as identifier.public;
    input r1 as identifier.public;
    input r2 as identifier.public;
    input r3 as address.public;
    get.or_use.dynamic r0 r1 r2[r3] 0u64 into r4 as u64;
    set r4 into result[r3];
