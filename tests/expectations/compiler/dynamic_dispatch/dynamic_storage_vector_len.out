program test.aleo;

function lookup:
    input r0 as field.private;
    async lookup r0 into r1;
    output r1 as test.aleo/lookup.future;

finalize lookup:
    input r0 as field.public;
    get.or_use.dynamic r0 'aleo' 'entries__len__'[false] 0u32 into r1 as u32;

constructor:
    assert.eq edition 0u16;
