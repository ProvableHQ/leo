program test.aleo;

mapping counts:
    key as u32.public;
    value as u32.public;

function main:
    input r0 as field.private;
    input r1 as field.private;
    input r2 as field.private;
    input r3 as u32.private;
    call.dynamic r0 r1 r2 with r3 (as u32.private) into r4 r5 (as u32.private dynamic.future);
    async main r5 into r6;
    output r4 as u32.private;
    output r6 as test.aleo/main.future;

finalize main:
    input r0 as dynamic.future;
    await r0;
