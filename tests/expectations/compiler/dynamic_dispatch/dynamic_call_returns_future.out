program test.aleo;

function main:
    input r0 as field.private;
    input r1 as field.private;
    input r2 as field.private;
    input r3 as u64.private;
    call.dynamic r0 r1 r2 with r3 (as u64.private) into r4 (as dynamic.future);
    async main r4 into r5;
    output r5 as test.aleo/main.future;

finalize main:
    input r0 as dynamic.future;
    await r0;
