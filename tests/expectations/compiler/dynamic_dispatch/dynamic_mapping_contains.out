program test.aleo;

function has_account:
    input r0 as field.private;
    input r1 as address.private;
    async has_account r0 r1 into r2;
    output r2 as test.aleo/has_account.future;

finalize has_account:
    input r0 as field.public;
    input r1 as address.public;
    contains.dynamic r0 'aleo' 'balances'[r1] into r2;
    assert.eq r2 true;
