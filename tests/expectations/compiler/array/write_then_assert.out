program test.aleo;

struct S:
    x as u8;
    y as u32;

function write_then_assert:
    input r0 as u8.public;
    input r1 as u8.public;
    cast r0 r1 r0 r1 into r2 as [u8; 4u32];
    cast r2[0u32] r2[1u32] r2[2u32] r2[3u32] into r3 as [u8; 4u32];
    assert.eq r3 r2;
    output r0 as u8.public;

function write_then_assert_struct:
    input r0 as u8.public;
    input r1 as u32.public;
    cast r0 r1 into r2 as S;
    cast r0 r1 into r3 as S;
    assert.eq r3 r2;
    output r0 as u8.public;

constructor:
    assert.eq edition 0u16;
