program test.aleo;

function write_then_repeat:
    input r0 as u8.public;
    input r1 as u8.public;
    add r0 r1 into r2;
    add r2 1u8 into r3;
    cast r2 r3 into r4 as [u8; 2u32];
    cast r4 r4 r4 into r5 as [[u8; 2u32]; 3u32];
    output r5 as [[u8; 2u32]; 3u32].public;

constructor:
    assert.eq edition 0u16;
