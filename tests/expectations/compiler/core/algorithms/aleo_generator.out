program test.aleo;

function test_generator:
    output aleo::GENERATOR as group.private;

function test_generator_powers:
    output aleo::GENERATOR_POWERS as [group; 251u32].private;

function test_generator_powers_indexed:
    output aleo::GENERATOR_POWERS[0u32] as group.private;

function test_in_finalize:
    async test_in_finalize into r0;
    output r0 as test.aleo/test_in_finalize.future;

finalize test_in_finalize:
    assert.eq aleo::GENERATOR aleo::GENERATOR_POWERS[0u32];
