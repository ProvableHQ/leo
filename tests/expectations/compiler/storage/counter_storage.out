program test.aleo;

struct Optional__JzunLORyB8U:
    is_some as boolean;
    val as u32;

mapping counter__:
    key as boolean.public;
    value as u32.public;

function initialize:
    async initialize into r0;
    output r0 as test.aleo/initialize.future;

finalize initialize:
    set 0u32 into counter__[false];

function increment:
    async increment into r0;
    output r0 as test.aleo/increment.future;

finalize increment:
    contains counter__[false] into r0;
    get.or_use counter__[false] 0u32 into r1;
    cast true r1 into r2 as Optional__JzunLORyB8U;
    ternary r0 r2.is_some false into r3;
    ternary r0 r1 0u32 into r4;
    cast r3 r4 into r5 as Optional__JzunLORyB8U;
    ternary r5.is_some r5.val 0u32 into r6;
    add r6 1u32 into r7;
    set r7 into counter__[false];
    contains counter__[false] into r8;
    get.or_use counter__[false] 0u32 into r9;
    cast true r9 into r10 as Optional__JzunLORyB8U;
    ternary r8 r10.is_some false into r11;
    ternary r8 r9 0u32 into r12;
    cast r11 r12 into r13 as Optional__JzunLORyB8U;
    assert.eq r13.is_some true;
    is.eq r13.val r7 into r14;
    assert.eq r14 true;

constructor:
    assert.eq edition 0u16;
