    get.or_use vec__len__[false] 0u32 into r4;
    add r4 1u32 into r5;
    set r5 into vec__len__[false];
    set 20u32 into vec__[r4];
    get.or_use vec__len__[false] 0u32 into r6;
    add r6 1u32 into r7;
    set r7 into vec__len__[false];
    set 30u32 into vec__[r6];
