    ternary r18 r20.val r21.val into r23;
    cast r22 r23 into r24 as Optional__EsDmm5O6sv6;
    is.eq r24.val 20u32 into r25;
    assert.eq r25 true;
    get.or_use vec__len__[false] 0u32 into r26;
    lt 1u32 r26 into r27;
    assert.eq r27 true;
    set 25u32 into vec__[1u32];
    get.or_use vec__len__[false] 0u32 into r28;
    lt 1u32 r28 into r29;
    get.or_use vec__[1u32] 0u32 into r30;
    cast true r30 into r31 as Optional__EsDmm5O6sv6;
    cast false 0u32 into r32 as Optional__EsDmm5O6sv6;
    ternary r29 r31.is_some r32.is_some into r33;
    ternary r29 r31.val r32.val into r34;
    cast r33 r34 into r35 as Optional__EsDmm5O6sv6;
    assert.eq r35.is_some true;
    lt 1u32 r28 into r36;
    get.or_use vec__[1u32] 0u32 into r37;
    cast true r37 into r38 as Optional__EsDmm5O6sv6;
    cast false 0u32 into r39 as Optional__EsDmm5O6sv6;
    ternary r36 r38.is_some r39.is_some into r40;
    ternary r36 r38.val r39.val into r41;
    cast r40 r41 into r42 as Optional__EsDmm5O6sv6;
    is.eq r42.val 25u32 into r43;
    assert.eq r43 true;
    get.or_use vec__len__[false] 0u32 into r44;
    lt 2u32 r44 into r45;
    assert.eq r45 true;
    sub r44 1u32 into r46;
    set r46 into vec__len__[false];
    sub r44 1u32 into r47;
    get vec__[r47] into r48;
    set r48 into vec__[2u32];
    lt 2u32 r44 into r49;
    get vec__[2u32] into r50;
    cast true r50 into r51 as Optional__EsDmm5O6sv6;
    cast false 0u32 into r52 as Optional__EsDmm5O6sv6;
    ternary r49 r51.is_some r52.is_some into r53;
    ternary r49 r51.val r52.val into r54;
    cast r53 r54 into r55 as Optional__EsDmm5O6sv6;
    assert.eq r55.is_some true;
    lt 2u32 r44 into r56;
    get vec__[2u32] into r57;
    cast true r57 into r58 as Optional__EsDmm5O6sv6;
    cast false 0u32 into r59 as Optional__EsDmm5O6sv6;
    ternary r56 r58.is_some r59.is_some into r60;
    ternary r56 r58.val r59.val into r61;
    cast r60 r61 into r62 as Optional__EsDmm5O6sv6;
    is.eq r62.val 30u32 into r63;
    assert.eq r63 true;
    get.or_use vec__len__[false] 0u32 into r64;
    is.eq r64 2u32 into r65;
    assert.eq r65 true;
    get.or_use vec__len__[false] 0u32 into r66;
    gt r66 0u32 into r67;
    branch.eq r67 false to end_then_0_0;
    sub r66 1u32 into r68;
    set r68 into vec__len__[false];
    branch.eq true true to end_otherwise_0_1;
    position end_then_0_0;
    position end_otherwise_0_1;
    gt r66 0u32 into r69;
    sub r66 1u32 into r70;
    get.or_use vec__[r70] 0u32 into r71;
    cast true r71 into r72 as Optional__EsDmm5O6sv6;
    cast false 0u32 into r73 as Optional__EsDmm5O6sv6;
    ternary r69 r72.is_some r73.is_some into r74;
    ternary r69 r72.val r73.val into r75;
    cast r74 r75 into r76 as Optional__EsDmm5O6sv6;
    assert.eq r76.is_some true;
    gt r66 0u32 into r77;
    sub r66 1u32 into r78;
    get.or_use vec__[r78] 0u32 into r79;
    cast true r79 into r80 as Optional__EsDmm5O6sv6;
    cast false 0u32 into r81 as Optional__EsDmm5O6sv6;
    ternary r77 r80.is_some r81.is_some into r82;
