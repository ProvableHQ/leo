program signature_storage.aleo;

mapping sig__:
    key as boolean.public;
    value as signature.public;

mapping sig_array__:
    key as boolean.public;
    value as [signature; 2u32].public;

mapping sig_vec__:
    key as u32.public;
    value as signature.public;

mapping sig_vec__len__:
    key as boolean.public;
    value as u32.public;

function foo:
