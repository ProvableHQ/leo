    assert.eq r6 true;
    contains mid1.aleo/flag__[false] into r7;
    get.or_use mid1.aleo/flag__[false] false into r8;
    cast true r8 into r9 as Optional__ATAkdHctJwx;
    ternary r7 r9.is_some false into r10;
    ternary r7 r8 false into r11;
    cast r10 r11 into r12 as Optional__ATAkdHctJwx;
    assert.eq r12.is_some true;
    is.eq r12.val true into r13;
    assert.eq r13 true;
    contains mid2.aleo/counter__[false] into r14;
    get.or_use mid2.aleo/counter__[false] 0u8 into r15;
    cast true r15 into r16 as Optional__3aph2JMPtnA;
    ternary r14 r16.is_some false into r17;
    ternary r14 r15 0u8 into r18;
    cast r17 r18 into r19 as Optional__3aph2JMPtnA;
    assert.eq r19.is_some true;
    is.eq r19.val 7u8 into r20;
    assert.eq r20 true;

function test_fallback:
    async test_fallback into r0;
    output r0 as top.aleo/test_fallback.future;

finalize test_fallback:
    contains base.aleo/val_u32__[false] into r0;
    get.or_use base.aleo/val_u32__[false] 0u32 into r1;
    cast true r1 into r2 as Optional__JzunLORyB8U;
    ternary r0 r2.is_some false into r3;
    ternary r0 r1 0u32 into r4;
    cast r3 r4 into r5 as Optional__JzunLORyB8U;
    ternary r5.is_some r5.val 0u32 into r6;
    is.eq r6 0u32 into r7;
    assert.eq r7 true;
    contains mid1.aleo/flag__[false] into r8;
    get.or_use mid1.aleo/flag__[false] false into r9;
    cast true r9 into r10 as Optional__ATAkdHctJwx;
    ternary r8 r10.is_some false into r11;
    ternary r8 r9 false into r12;
    cast r11 r12 into r13 as Optional__ATAkdHctJwx;
    ternary r13.is_some r13.val false into r14;
    is.eq r14 false into r15;
    assert.eq r15 true;
    contains mid2.aleo/counter__[false] into r16;
    get.or_use mid2.aleo/counter__[false] 0u8 into r17;
    cast true r17 into r18 as Optional__3aph2JMPtnA;
    ternary r16 r18.is_some false into r19;
    ternary r16 r17 0u8 into r20;
    cast r19 r20 into r21 as Optional__3aph2JMPtnA;
    ternary r21.is_some r21.val 11u8 into r22;
    is.eq r22 11u8 into r23;
    assert.eq r23 true;

function test_none:
