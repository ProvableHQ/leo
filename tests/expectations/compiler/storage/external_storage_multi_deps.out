import base.aleo;
import mid1.aleo;
program mid2.aleo;

struct Optional__JzunLORyB8U:
    is_some as boolean;
    val as u32;

struct Optional__ATAkdHctJwx:
    is_some as boolean;
    val as boolean;

mapping counter__:
    key as boolean.public;
    value as u8.public;

function init:
    async init into r0;
    output r0 as mid2.aleo/init.future;

finalize init:
    set 7u8 into counter__[false];
    contains base.aleo/val_u32__[false] into r0;
    get.or_use base.aleo/val_u32__[false] 0u32 into r1;
    cast true r1 into r2 as Optional__JzunLORyB8U;
    cast false 0u32 into r3 as Optional__JzunLORyB8U;
    ternary r0 r2.is_some r3.is_some into r4;
    ternary r0 r2.val r3.val into r5;
    cast r4 r5 into r6 as Optional__JzunLORyB8U;
    assert.eq r6.is_some true;
    is.eq r6.val 99u32 into r7;
    assert.eq r7 true;
    contains mid1.aleo/flag__[false] into r8;
    get.or_use mid1.aleo/flag__[false] false into r9;
    cast true r9 into r10 as Optional__ATAkdHctJwx;
    cast false false into r11 as Optional__ATAkdHctJwx;
    ternary r8 r10.is_some r11.is_some into r12;
    ternary r8 r10.val r11.val into r13;
    cast r12 r13 into r14 as Optional__ATAkdHctJwx;
    assert.eq r14.is_some true;
    is.eq r14.val true into r15;
    assert.eq r15 true;

function wipe:
    async wipe into r0;
    output r0 as mid2.aleo/wipe.future;

finalize wipe:
    remove counter__[false];
    contains mid1.aleo/flag__[false] into r0;
    get.or_use mid1.aleo/flag__[false] false into r1;
    cast true r1 into r2 as Optional__ATAkdHctJwx;
    cast false false into r3 as Optional__ATAkdHctJwx;
    ternary r0 r2.is_some r3.is_some into r4;
    ternary r0 r2.val r3.val into r5;
    cast r4 r5 into r6 as Optional__ATAkdHctJwx;
    cast false false into r7 as Optional__ATAkdHctJwx;
    is.eq r6 r7 into r8;
    assert.eq r8 true;

constructor:
    assert.eq edition 0u16;
