    output r0 as mid2.aleo/init.future;

finalize init:
    set 7u8 into counter__[false];
    contains base.aleo/val_u32__[false] into r0;
    get.or_use base.aleo/val_u32__[false] 0u32 into r1;
    ternary r0 r1 0u32 into r2;
    assert.eq r0 true;
    is.eq r2 99u32 into r3;
    assert.eq r3 true;
    contains mid1.aleo/flag__[false] into r4;
    get.or_use mid1.aleo/flag__[false] false into r5;
    ternary r4 r5 false into r6;
    assert.eq r4 true;
    is.eq r6 true into r7;
    assert.eq r7 true;

