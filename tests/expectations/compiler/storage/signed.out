    output r0 as signed.aleo/initialize.future;

finalize initialize:
    set -1i8 into counter_i8__[false];
    set -2i16 into counter_i16__[false];
    set -3i32 into counter_i32__[false];
    set -4i64 into counter_i64__[false];
    set -5i128 into counter_i128__[false];

