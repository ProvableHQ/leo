program dep.aleo;

mapping dep_data:
    key as u32.public;
    value as u32.public;

function update:
    input r0 as u32.private;
    async update r0 into r1;
    output r1 as dep.aleo/update.future;

finalize update:
    input r0 as u32.public;
    set r0 into dep_data[0u32];
// --- Next Program --- //
import dep.aleo;
program caller.aleo;

mapping balances:
    key as u32.public;
    value as u32.public;

function do_work:
    input r0 as u32.private;
    call dep.aleo/update r0 into r1;
    async do_work r1 r0 into r2;
    output r2 as caller.aleo/do_work.future;

finalize do_work:
    input r0 as dep.aleo/update.future;
    input r1 as u32.public;
    gt r1 100u32 into r2;
    branch.eq r2 false to end_then_0_0;
    gt r1 200u32 into r3;
    branch.eq r3 false to end_then_1_2;
    gt r1 300u32 into r4;
    branch.eq r4 false to end_then_2_4;
    gt r1 400u32 into r5;
    branch.eq r5 false to end_then_3_6;
    await r0;
    branch.eq true true to end_otherwise_3_7;
    position end_then_3_6;
    set 0u32 into balances[99u32];
    position end_otherwise_3_7;
    branch.eq true true to end_otherwise_2_5;
    position end_then_2_4;
    set 0u32 into balances[98u32];
    position end_otherwise_2_5;
    branch.eq true true to end_otherwise_1_3;
    position end_then_1_2;
    set 0u32 into balances[97u32];
    position end_otherwise_1_3;
    branch.eq true true to end_otherwise_0_1;
    position end_then_0_0;
    set 0u32 into balances[96u32];
    position end_otherwise_0_1;
    set r1 into balances[0u32];
