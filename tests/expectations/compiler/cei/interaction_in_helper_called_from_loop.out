program dep.aleo;

mapping dep_data:
    key as u32.public;
    value as u32.public;

function update:
    input r0 as u32.private;
    async update r0 into r1;
    output r1 as dep.aleo/update.future;

finalize update:
    input r0 as u32.public;
    set r0 into dep_data[0u32];

constructor:
    assert.eq edition 0u16;
// --- Next Program --- //
import dep.aleo;
program caller.aleo;

mapping counters:
    key as u32.public;
    value as u32.public;

function do_work:
    input r0 as u32.private;
    call dep.aleo/update r0 into r1;
    async do_work r1 r0 into r2;
    output r2 as caller.aleo/do_work.future;

finalize do_work:
    input r0 as dep.aleo/update.future;
    input r1 as u32.public;
    await r0;
    set r1 into counters[0u32];
    await r0;
    add r1 1u32 into r2;
    set r2 into counters[1u32];
    await r0;
    add r1 2u32 into r3;
    set r3 into counters[2u32];

constructor:
    assert.eq edition 0u16;
