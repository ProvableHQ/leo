Warning [WCEI03713003]: Loop body contains both interactions (Final.run()) and state operations (checks or effects), which violates the CEI pattern.
    --> compiler-test:18:5
     |
  18 |     for i: u32 in 0u32..3u32 {
     |     ^^^^^^^^^^^^^^^^^^^^^^^^^^
  19 |         // [I] Interaction hidden in helper
     |         ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
  20 |         run_future(f);
     |         ^^^^^^^^^^^^^^
  21 |         // [E] Effect after interaction-via-helper
     |         ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
  22 |         Mapping::set(counters, i, a + i);
     |         ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
  23 |     }
     |     ^
     |
     = Restructure the loop so that interactions do not occur alongside checks or effects within the same iteration.
Warning [WCEI03713001]: Effect operation `_mapping_set` occurs after an interaction (Final.run()).
    --> compiler-test:22:9
     |
  22 |         Mapping::set(counters, i, a + i);
     |         ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
     |
     = Move all effects (state writes) before any calls to `.run()` to prevent reentrancy vulnerabilities.
program dep.aleo;

mapping dep_data:
    key as u32.public;
    value as u32.public;

function update:
    input r0 as u32.private;
    async update r0 into r1;
    output r1 as dep.aleo/update.future;

finalize update:
    input r0 as u32.public;
    set r0 into dep_data[0u32];
// --- Next Program --- //
import dep.aleo;
program caller.aleo;

mapping counters:
    key as u32.public;
    value as u32.public;

function do_work:
    input r0 as u32.private;
    call dep.aleo/update r0 into r1;
    async do_work r1 r0 into r2;
    output r2 as caller.aleo/do_work.future;

finalize do_work:
    input r0 as dep.aleo/update.future;
    input r1 as u32.public;
    await r0;
    add r1 0u32 into r2;
    set r2 into counters[0u32];
    await r0;
    add r1 1u32 into r3;
    set r3 into counters[1u32];
    await r0;
    add r1 2u32 into r4;
    set r4 into counters[2u32];
