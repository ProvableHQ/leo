program oracle.aleo;

mapping prices:
    key as u32.public;
    value as u64.public;

function get_price:
    input r0 as u32.private;
    async get_price r0 into r1;
    output 500u64 as u64.private;
    output r1 as oracle.aleo/get_price.future;

finalize get_price:
    input r0 as u32.public;
    set 50u64 into prices[r0];
// --- Next Program --- //
import oracle.aleo;
program trader.aleo;

mapping positions:
    key as u32.public;
    value as u64.public;

function trade:
    input r0 as u32.private;
    call oracle.aleo/get_price r0 into r1 r2;
    async trade r1 r0 r2 into r3;
    output r3 as trader.aleo/trade.future;

finalize trade:
    input r0 as u64.public;
    input r1 as u32.public;
    input r2 as oracle.aleo/get_price.future;
    mul r0 2u64 into r3;
    set r3 into positions[r1];
    await r2;

constructor:
    assert.eq edition 0u16;
