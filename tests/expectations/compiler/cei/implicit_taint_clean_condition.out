program oracle.aleo;

mapping prices:
    key as u32.public;
    value as u64.public;

function get_price:
    input r0 as u32.private;
    async get_price r0 into r1;
    output 500u64 as u64.private;
    output r1 as oracle.aleo/get_price.future;

finalize get_price:
    input r0 as u32.public;
    set 50u64 into prices[r0];
// --- Next Program --- //
import oracle.aleo;
program trader.aleo;

mapping positions:
    key as u32.public;
    value as u64.public;

function trade:
    input r0 as u32.private;
    input r1 as u64.private;
    call oracle.aleo/get_price r0 into r2 r3;
    add r2 1u64 into r4;
    gt r4 0u64 into r5;
    assert.eq r5 true;
    gt r1 400u64 into r6;
    ternary r6 1u64 0u64 into r7;
    async trade r0 r7 r3 into r8;
    output r8 as trader.aleo/trade.future;

finalize trade:
    input r0 as u32.public;
    input r1 as u64.public;
    input r2 as oracle.aleo/get_price.future;
    set r1 into positions[r0];
    await r2;

constructor:
    assert.eq edition 0u16;
