program dep.aleo;

mapping dep_data:
    key as u32.public;
    value as u32.public;

function update:
    input r0 as u32.private;
    async update r0 into r1;
    output r1 as dep.aleo/update.future;

finalize update:
    input r0 as u32.public;
    set r0 into dep_data[0u32];

constructor:
    assert.eq edition 0u16;
// --- Next Program --- //
import dep.aleo;
program caller.aleo;

function do_work:
    input r0 as u32.private;
    call dep.aleo/update r0 into r1;
    async do_work r1 into r2;
    output r2 as caller.aleo/do_work.future;

finalize do_work:
    input r0 as dep.aleo/update.future;
    await r0;

constructor:
    assert.eq edition 0u16;
