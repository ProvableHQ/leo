import token.aleo;
program caller.aleo;

mapping decisions:
    key as u32.public;
    value as u32.public;

function make_decision:
    input r0 as u32.private;
    call token.aleo/get_supply r0 into r1 r2;
    async make_decision r2 r1 r0 into r3;
    output r3 as caller.aleo/make_decision.future;

finalize make_decision:
    input r0 as token.aleo/get_supply.future;
    input r1 as u32.public;
    input r2 as u32.public;
    set r1 into decisions[r2];
    await r0;
