program token.aleo;

mapping supply:
    key as u32.public;
    value as u32.public;

function get_supply:
    input r0 as u32.private;
    async get_supply r0 into r1;
    output 100u32 as u32.private;
    output r1 as token.aleo/get_supply.future;

finalize get_supply:
    input r0 as u32.public;
    get.or_use supply[r0] 0u32 into r1;
    set r1 into supply[r0];
