import oracle.aleo;
program trader.aleo;

mapping positions:
    key as u32.public;
    value as u64.public;

function trade:
    input r0 as u32.private;
    call oracle.aleo/get_price r0 into r1 r2;
    async trade r2 r1 r0 into r3;
    output r3 as trader.aleo/trade.future;

finalize trade:
    input r0 as oracle.aleo/get_price.future;
    input r1 as u64.public;
    input r2 as u32.public;
    gt r1 400u64 into r3;
    branch.eq r3 false to end_then_0_0;
    set r1 into positions[r2];
    branch.eq true true to end_otherwise_0_1;
    position end_then_0_0;
    set 0u64 into positions[r2];
    position end_otherwise_0_1;
    await r0;
