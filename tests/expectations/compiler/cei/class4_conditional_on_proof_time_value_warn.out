program oracle.aleo;

mapping prices:
    key as u32.public;
    value as u64.public;

function get_price:
    input r0 as u32.private;
    async get_price r0 into r1;
    output 500u64 as u64.private;
    output r1 as oracle.aleo/get_price.future;

finalize get_price:
    input r0 as u32.public;
    get.or_use prices[r0] 0u64 into r1;
    set r1 into prices[r0];
