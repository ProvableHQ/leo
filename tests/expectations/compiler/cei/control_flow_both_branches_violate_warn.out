Warning [WCEI03713001]: Effect operation `_mapping_set` occurs after an interaction (Final.run()).
    --> compiler-test:20:9
     |
  20 |         Mapping::set(balances, 0u32, val + a);
     |         ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
     |
     = Move all effects (state writes) before any calls to `.run()` to prevent reentrancy vulnerabilities.
program dep.aleo;

mapping dep_data:
    key as u32.public;
    value as u32.public;

function update:
    input r0 as u32.private;
    async update r0 into r1;
    output r1 as dep.aleo/update.future;

finalize update:
    input r0 as u32.public;
    set r0 into dep_data[0u32];
// --- Next Program --- //
import dep.aleo;
program caller.aleo;

mapping balances:
    key as u32.public;
    value as u32.public;

function do_work:
    input r0 as u32.private;
    call dep.aleo/update r0 into r1;
    async do_work r1 r0 into r2;
    output r2 as caller.aleo/do_work.future;

finalize do_work:
    input r0 as dep.aleo/update.future;
    input r1 as u32.public;
    gt r1 5u32 into r2;
    branch.eq r2 false to end_then_0_0;
    get.or_use balances[0u32] 0u32 into r3;
    await r0;
    add r3 r1 into r4;
    set r4 into balances[0u32];
    branch.eq true true to end_otherwise_0_1;
    position end_then_0_0;
    set r1 into balances[1u32];
    await r0;
    position end_otherwise_0_1;
