program oracle.aleo;

mapping prices:
    key as u32.public;
    value as u64.public;

function get_price:
    input r0 as u32.private;
    async get_price r0 into r1;
    output 500u64 as u64.private;
    output r1 as oracle.aleo/get_price.future;

finalize get_price:
    input r0 as u32.public;
    set 50u64 into prices[r0];

constructor:
    assert.eq edition 0u16;
// --- Next Program --- //
import oracle.aleo;
program trader.aleo;

mapping positions:
    key as u32.public;
    value as u64.public;

function trade:
    input r0 as u32.private;
    call oracle.aleo/get_price r0 into r1 r2;
    gt r1 400u64 into r3;
    ternary r3 1u64 0u64 into r4;
    async trade r0 r4 r2 into r5;
    output r5 as trader.aleo/trade.future;

finalize trade:
    input r0 as u32.public;
    input r1 as u64.public;
    input r2 as oracle.aleo/get_price.future;
    set r1 into positions[r0];
    await r2;

constructor:
    assert.eq edition 0u16;
