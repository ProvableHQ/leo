program dep.aleo;

mapping shared:
    key as u32.public;
    value as u32.public;

function modify:
    input r0 as u32.private;
    async modify r0 into r1;
    output r1 as dep.aleo/modify.future;

finalize modify:
    input r0 as u32.public;
    set r0 into shared[0u32];

view shared_value:
    input r0 as u32.public;
    get.or_use shared[r0] 0u32 into r1;
    output r1 as u32.public;

constructor:
    assert.eq edition 0u16;
