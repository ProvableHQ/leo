import dep.aleo;
program caller.aleo;

mapping balances:
    key as u32.public;
    value as u32.public;

function do_work:
    input r0 as u32.private;
    call dep.aleo/modify r0 into r1;
    async do_work r1 into r2;
    output r2 as caller.aleo/do_work.future;

finalize do_work:
    input r0 as dep.aleo/modify.future;
    await r0;
    call dep.aleo/shared_value 0u32 into r1;
    gte r1 0u32 into r2;
    assert.eq r2 true;

constructor:
    assert.eq edition 0u16;


