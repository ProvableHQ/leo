import dep.aleo;
program caller.aleo;

mapping balances:
    key as u32.public;
    value as u32.public;

function do_work:
    input r0 as u32.private;
    call dep.aleo/update r0 into r1;
    async do_work r0 r1 into r2;
    output r2 as caller.aleo/do_work.future;

finalize do_work:
    input r0 as u32.public;
    input r1 as dep.aleo/update.future;
    set r0 into balances[0u32];
    await r1;
    set r0 into balances[1u32];
