program dep.aleo;

mapping shared:
    key as u32.public;
    value as u32.public;

function modify:
    input r0 as u32.private;
    async modify r0 into r1;
    output r1 as dep.aleo/modify.future;

finalize modify:
    input r0 as u32.public;
    set r0 into shared[0u32];

constructor:
    assert.eq edition 0u16;
// --- Next Program --- //
import dep.aleo;
program caller.aleo;

mapping balances:
    key as u32.public;
    value as u32.public;

view balance_of:
    input r0 as u32.public;
    get.or_use balances[r0] 0u32 into r1;
    output r1 as u32.public;

function do_work:
    input r0 as u32.private;
    call dep.aleo/modify r0 into r1;
    async do_work r1 into r2;
    output r2 as caller.aleo/do_work.future;

finalize do_work:
    input r0 as dep.aleo/modify.future;
    await r0;
    call balance_of 0u32 into r1;
    gte r1 0u32 into r2;
    assert.eq r2 true;
    await r0;
    call balance_of 1u32 into r3;
    gte r3 0u32 into r4;
    assert.eq r4 true;
    await r0;
    call balance_of 2u32 into r5;
    gte r5 0u32 into r6;
    assert.eq r6 true;

constructor:
    assert.eq edition 0u16;
