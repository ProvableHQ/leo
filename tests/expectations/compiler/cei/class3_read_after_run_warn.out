program dep.aleo;

mapping shared:
    key as u32.public;
    value as u32.public;

function modify:
    input r0 as u32.private;
    async modify r0 into r1;
    output r1 as dep.aleo/modify.future;

finalize modify:
    input r0 as u32.public;
    set r0 into shared[0u32];

constructor:
    assert.eq edition 0u16;
// --- Next Program --- //
import dep.aleo;
program caller.aleo;

mapping balances:
    key as u32.public;
    value as u32.public;

function do_work:
    input r0 as u32.private;
    call dep.aleo/modify r0 into r1;
    async do_work r1 r0 into r2;
    output r2 as caller.aleo/do_work.future;

finalize do_work:
    input r0 as dep.aleo/modify.future;
    input r1 as u32.public;
    await r0;
    get.or_use balances[0u32] 0u32 into r2;
    gte r2 0u32 into r3;
    assert.eq r3 true;

constructor:
    assert.eq edition 0u16;
