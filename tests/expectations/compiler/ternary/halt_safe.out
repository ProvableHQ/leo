program test.aleo;

function divide:
    input r0 as boolean.private;
    input r1 as u8.private;
    input r2 as u8.private;
    ternary r0 r2 1u8 into r3;
    div r1 r3 into r4;
    ternary r0 r4 0u8 into r5;
    output r5 as u8.private;

function signed_divide:
    input r0 as boolean.private;
    input r1 as i8.private;
    input r2 as i8.private;
    ternary r0 r2 1i8 into r3;
    div r1 r3 into r4;
    ternary r0 r4 0i8 into r5;
    output r5 as i8.private;

function nested:
    input r0 as boolean.private;
    input r1 as boolean.private;
    input r2 as u8.private;
    input r3 as u8.private;
    and r0 r1 into r4;
    ternary r4 r3 1u8 into r5;
    div r2 r5 into r6;
    ternary r1 r6 1u8 into r7;
    ternary r0 r7 2u8 into r8;
    output r8 as u8.private;

function select:
    input r0 as boolean.private;
    input r1 as u8.private;
    input r2 as u8.private;
    ternary r0 r1 r2 into r3;
    output r3 as u8.private;

constructor:
    assert.eq edition 0u16;
