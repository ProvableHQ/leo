program main.aleo;

function compute:
    input r0 as u32.private;
    input r1 as u32.private;
    lt r0 r1 into r2;
    ternary r2 r0 r1 into r3;
    gt r0 r1 into r4;
    ternary r4 r0 r1 into r5;
    output r3 as u32.private;
    output r5 as u32.private;

constructor:
    assert.eq edition 0u16;
