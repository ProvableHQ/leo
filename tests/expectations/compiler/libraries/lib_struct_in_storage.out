program test.aleo;

struct TokenInfo__CxbbwT70PGX:
    name as u128;
    symbol as u128;
    decimals as u8;
    supply as u128;
    max_supply as u128;

struct Optional__An66AtVsP75:
    is_some as boolean;
    val as TokenInfo__CxbbwT70PGX;

mapping token_info__:
    key as boolean.public;
    value as TokenInfo__CxbbwT70PGX.public;

function unwrap_info:
    async unwrap_info into r0;
    output r0 as test.aleo/unwrap_info.future;

finalize unwrap_info:
    contains token_info__[false] into r0;
    cast 0u128 0u128 0u8 0u128 0u128 into r1 as TokenInfo__CxbbwT70PGX;
    get.or_use token_info__[false] r1 into r2;
    cast true r2 into r3 as Optional__An66AtVsP75;
    cast 0u128 0u128 0u8 0u128 0u128 into r4 as TokenInfo__CxbbwT70PGX;
    ternary r0 r2.name r4.name into r5;
    ternary r0 r2.symbol r4.symbol into r6;
    ternary r0 r2.decimals r4.decimals into r7;
    ternary r0 r2.supply r4.supply into r8;
    ternary r0 r2.max_supply r4.max_supply into r9;
    cast r5 r6 r7 r8 r9 into r10 as TokenInfo__CxbbwT70PGX;
    ternary r0 r3.is_some false into r11;
    cast r11 r10 into r12 as Optional__An66AtVsP75;
    assert.eq r12.is_some true;
    assert.eq r12.val.decimals 8u8;

constructor:
    assert.eq edition 0u16;
