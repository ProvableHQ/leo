program test.aleo;

struct TokenInfo__CxbbwT70PGX:
    name as u128;
    symbol as u128;
    decimals as u8;
    supply as u128;
    max_supply as u128;

struct Optional__An66AtVsP75:
    is_some as boolean;
    val as TokenInfo__CxbbwT70PGX;

mapping token_info__:
    key as boolean.public;
    value as TokenInfo__CxbbwT70PGX.public;

function unwrap_info:
    async unwrap_info into r0;
    output r0 as test.aleo/unwrap_info.future;

finalize unwrap_info:
    contains token_info__[false] into r0;
    cast 0u128 0u128 0u8 0u128 0u128 into r1 as TokenInfo__CxbbwT70PGX;
    get.or_use token_info__[false] r1 into r2;
    cast true r2 into r3 as Optional__An66AtVsP75;
    cast 0u128 0u128 0u8 0u128 0u128 into r4 as TokenInfo__CxbbwT70PGX;
    cast false r4 into r5 as Optional__An66AtVsP75;
    ternary r0 r3.val.name r5.val.name into r6;
    ternary r0 r3.val.symbol r5.val.symbol into r7;
    ternary r0 r3.val.decimals r5.val.decimals into r8;
    ternary r0 r3.val.supply r5.val.supply into r9;
    ternary r0 r3.val.max_supply r5.val.max_supply into r10;
    cast r6 r7 r8 r9 r10 into r11 as TokenInfo__CxbbwT70PGX;
    ternary r0 r3.is_some r5.is_some into r12;
    cast r12 r11 into r13 as Optional__An66AtVsP75;
    assert.eq r13.is_some true;
    assert.eq r13.val.decimals 8u8;

constructor:
    assert.eq edition 0u16;
