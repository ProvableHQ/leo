program impl_ops.aleo;

function process:
    input r0 as u32.private;
    add r0 10u32 into r1;
    output r1 as u32.private;

constructor:
    assert.eq edition 0u16;
// --- Next Program --- //
import impl_ops.aleo;
program caller.aleo;

function call_process:
    input r0 as field.private;
    input r1 as u32.private;
    call.dynamic r0 'aleo' 'process' with r1 (as u32.private) into r2 (as u32.private);
    output r2 as u32.private;

constructor:
    assert.eq edition 0u16;
