program test.aleo;

mapping account:
    key as address.public;
    value as u64.public;

function mint:
    input r0 as address.public;
    input r1 as u64.public;
    async mint r0 r1 into r2;
    output r2 as test.aleo/mint.future;

finalize mint:
    input r0 as address.public;
    input r1 as u64.public;
    add r1 1u64 into r2;
    set r2 into account[r0];
