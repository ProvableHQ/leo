program test.aleo;

closure sum_of:
    input r0 as u32;
    input r1 as u32;
    add r0 r1 into r2;
    output r2 as u32;

function main:
    input r0 as u32.private;
    input r1 as u32.private;
    input r2 as u32.private;
    call sum_of r0 r1 into r3;
    call sum_of r1 r2 into r4;
    output r3 as u32.private;
    output r4 as u32.private;
