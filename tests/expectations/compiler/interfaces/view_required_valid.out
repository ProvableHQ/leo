program scratch.aleo;

mapping balances:
    key as address.public;
    value as u128.public;

function transfer:
    input r0 as address.public;
    input r1 as u128.public;
    async transfer into r2;
    output r2 as scratch.aleo/transfer.future;

finalize transfer:
    assert.eq true true;

view balance_of:
    input r0 as address.public;
    get.or_use balances[r0] 0u128 into r1;
    output r1 as u128.public;

constructor:
    assert.eq edition 0u16;
