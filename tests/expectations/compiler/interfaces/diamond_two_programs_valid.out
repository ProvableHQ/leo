// --- Next Program --- //
import lib1.aleo;
import lib2.aleo;
program test.aleo;

record Token:
    owner as address.private;

function transfer:
    input r0 as Token.record;
    cast r0.owner into r1 as Token.record;
    output r1 as Token.record;

function stake:
    input r0 as Token.record;
    cast r0.owner into r1 as Token.record;
    output r1 as Token.record;

function main:

constructor:
    assert.eq edition 0u16;


