program test.aleo;

mapping balances:
    key as address.public;
    value as [u64; 8u32].public;

function foo:
    input r0 as address.private;
    async foo r0 into r1;
    output r1 as test.aleo/foo.future;

finalize foo:
    input r0 as address.public;
    cast 0u64 0u64 0u64 0u64 0u64 0u64 0u64 0u64 into r1 as [u64; 8u32];
    get.or_use balances[r0] r1 into r2;
