program test.aleo;

record Token:
    owner as address.private;

function transfer:
    input r0 as Token.record;
    cast r0.owner into r1 as Token.record;
    output r1 as Token.record;

function stake:
    input r0 as Token.record;
    cast r0.owner into r1 as Token.record;
    output r1 as Token.record;

