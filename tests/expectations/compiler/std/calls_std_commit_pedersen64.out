program main.aleo;

function exercise:
    commit.ped64 true 1scalar into r0 as address;
    assert.eq r0 r0;
    commit.ped64 true 1scalar into r1 as field;
    assert.eq r1 r1;
    commit.ped64 true 1scalar into r2 as group;
    assert.eq r2 r2;
    commit.ped64 1u8 1scalar into r3 as address;
    assert.eq r3 r3;
    commit.ped64 1u8 1scalar into r4 as field;
    assert.eq r4 r4;
    commit.ped64 1u8 1scalar into r5 as group;
    assert.eq r5 r5;
    commit.ped64 1u16 1scalar into r6 as address;
    assert.eq r6 r6;
    commit.ped64 1u16 1scalar into r7 as field;
    assert.eq r7 r7;
    commit.ped64 1u16 1scalar into r8 as group;
    assert.eq r8 r8;
    commit.ped64 1u32 1scalar into r9 as address;
    assert.eq r9 r9;
    commit.ped64 1u32 1scalar into r10 as field;
    assert.eq r10 r10;
    commit.ped64 1u32 1scalar into r11 as group;
    assert.eq r11 r11;
    commit.ped64 1i8 1scalar into r12 as address;
    assert.eq r12 r12;
    commit.ped64 1i8 1scalar into r13 as field;
    assert.eq r13 r13;
    commit.ped64 1i8 1scalar into r14 as group;
    assert.eq r14 r14;
    commit.ped64 1i16 1scalar into r15 as address;
    assert.eq r15 r15;
    commit.ped64 1i16 1scalar into r16 as field;
    assert.eq r16 r16;
    commit.ped64 1i16 1scalar into r17 as group;
    assert.eq r17 r17;
    commit.ped64 1i32 1scalar into r18 as address;
    assert.eq r18 r18;
    commit.ped64 1i32 1scalar into r19 as field;
    assert.eq r19 r19;
    commit.ped64 1i32 1scalar into r20 as group;
    assert.eq r20 r20;

constructor:
    assert.eq edition 0u16;
