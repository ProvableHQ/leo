    assert.eq r41 r41;
    commit.bhp512 aleo1az8p9vlllyqwtj0c2g9svkd0e5v0p3zzdflwwrpa7kpe8xrfxgfqqpru7m 1scalar into r42 as address;
    assert.eq r42 r42;
    commit.bhp512 aleo1az8p9vlllyqwtj0c2g9svkd0e5v0p3zzdflwwrpa7kpe8xrfxgfqqpru7m 1scalar into r43 as field;
    assert.eq r43 r43;
    commit.bhp512 aleo1az8p9vlllyqwtj0c2g9svkd0e5v0p3zzdflwwrpa7kpe8xrfxgfqqpru7m 1scalar into r44 as group;
    assert.eq r44 r44;

constructor:
    assert.eq edition 0u16;
