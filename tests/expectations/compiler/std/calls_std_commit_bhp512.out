program main.aleo;

function exercise:
    commit.bhp512 true 1scalar into r0 as address;
    assert.eq r0 r0;
    commit.bhp512 true 1scalar into r1 as field;
    assert.eq r1 r1;
    commit.bhp512 true 1scalar into r2 as group;
    assert.eq r2 r2;
    commit.bhp512 1u8 1scalar into r3 as address;
    assert.eq r3 r3;
    commit.bhp512 1u8 1scalar into r4 as field;
    assert.eq r4 r4;
    commit.bhp512 1u8 1scalar into r5 as group;
    assert.eq r5 r5;
    commit.bhp512 1u16 1scalar into r6 as address;
    assert.eq r6 r6;
    commit.bhp512 1u16 1scalar into r7 as field;
    assert.eq r7 r7;
    commit.bhp512 1u16 1scalar into r8 as group;
    assert.eq r8 r8;
    commit.bhp512 1u32 1scalar into r9 as address;
    assert.eq r9 r9;
    commit.bhp512 1u32 1scalar into r10 as field;
    assert.eq r10 r10;
    commit.bhp512 1u32 1scalar into r11 as group;
    assert.eq r11 r11;
    commit.bhp512 1u64 1scalar into r12 as address;
    assert.eq r12 r12;
    commit.bhp512 1u64 1scalar into r13 as field;
    assert.eq r13 r13;
    commit.bhp512 1u64 1scalar into r14 as group;
    assert.eq r14 r14;
    commit.bhp512 1u128 1scalar into r15 as address;
    assert.eq r15 r15;
    commit.bhp512 1u128 1scalar into r16 as field;
    assert.eq r16 r16;
    commit.bhp512 1u128 1scalar into r17 as group;
    assert.eq r17 r17;
    commit.bhp512 1i8 1scalar into r18 as address;
    assert.eq r18 r18;
    commit.bhp512 1i8 1scalar into r19 as field;
    assert.eq r19 r19;
    commit.bhp512 1i8 1scalar into r20 as group;
    assert.eq r20 r20;
    commit.bhp512 1i16 1scalar into r21 as address;
    assert.eq r21 r21;
    commit.bhp512 1i16 1scalar into r22 as field;
    assert.eq r22 r22;
    commit.bhp512 1i16 1scalar into r23 as group;
    assert.eq r23 r23;
    commit.bhp512 1i32 1scalar into r24 as address;
    assert.eq r24 r24;
    commit.bhp512 1i32 1scalar into r25 as field;
    assert.eq r25 r25;
    commit.bhp512 1i32 1scalar into r26 as group;
    assert.eq r26 r26;
    commit.bhp512 1i64 1scalar into r27 as address;
    assert.eq r27 r27;
    commit.bhp512 1i64 1scalar into r28 as field;
    assert.eq r28 r28;
    commit.bhp512 1i64 1scalar into r29 as group;
    assert.eq r29 r29;
    commit.bhp512 1i128 1scalar into r30 as address;
    assert.eq r30 r30;
    commit.bhp512 1i128 1scalar into r31 as field;
    assert.eq r31 r31;
    commit.bhp512 1i128 1scalar into r32 as group;
    assert.eq r32 r32;
    commit.bhp512 1field 1scalar into r33 as address;
    assert.eq r33 r33;
    commit.bhp512 1field 1scalar into r34 as field;
    assert.eq r34 r34;
    commit.bhp512 1field 1scalar into r35 as group;
    assert.eq r35 r35;
    commit.bhp512 0group 1scalar into r36 as address;
    assert.eq r36 r36;
    commit.bhp512 0group 1scalar into r37 as field;
    assert.eq r37 r37;
    commit.bhp512 0group 1scalar into r38 as group;
    assert.eq r38 r38;
    commit.bhp512 1scalar 1scalar into r39 as address;
    assert.eq r39 r39;
    commit.bhp512 1scalar 1scalar into r40 as field;
    assert.eq r40 r40;
