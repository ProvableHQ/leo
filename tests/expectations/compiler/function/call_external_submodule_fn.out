program child.aleo;

function main:
    input r0 as u32.public;
    output r0 as u32.private;

constructor:
    assert.eq edition 0u16;
// --- Next Program --- //
import child.aleo;
program parent.aleo;

function main:
    input r0 as u32.private;
    add r0 1u32 into r1;
    output r1 as u32.private;

constructor:
    assert.eq edition 0u16;


---
Note: Treating dependencies as Aleo produces different results:

