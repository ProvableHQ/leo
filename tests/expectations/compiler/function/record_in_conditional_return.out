program test.aleo;

record Token:
    owner as address.private;
    amount as u64.private;

function mint_token:
    input r0 as address.private;
    input r1 as u64.private;
    input r2 as field.private;
    hash.psd2 r2 into r3 as field;
    is.eq 7202470996857839225873911078012225723419856133099120809866608931983814353616field r3 into r4;
    ternary r4 r0 r0 into r5;
    ternary r4 r1 0u64 into r6;
    cast r5 r6 into r7 as Token.record;
    output r7 as Token.record;

function mint_token2:
    input r0 as address.private;
    input r1 as u64.private;
    input r2 as field.private;
    hash.psd2 r2 into r3 as field;
    is.eq 7202470996857839225873911078012225723419856133099120809866608931983814353616field r3 into r4;
    ternary r4 r0 r0 into r5;
    ternary r4 r1 0u64 into r6;
    cast r5 r6 into r7 as Token.record;
    output r7 as Token.record;
