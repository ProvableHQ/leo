program child.aleo;

function main:
    input r0 as u32.public;
    input r1 as u32.private;
    add r0 r1 into r2;
    add r2 42u32 into r3;
    output r3 as u32.private;

constructor:
    assert.eq edition 0u16;
// --- Next Program --- //
import child.aleo;
program parent.aleo;

function main:
    output 0u32 as u32.private;

constructor:
    assert.eq edition 0u16;
