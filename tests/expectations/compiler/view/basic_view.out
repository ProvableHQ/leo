program test.aleo;

mapping balances:
    key as address.public;
    value as u64.public;

function main:
    input r0 as u32.private;
    add r0 1u32 into r1;
    output r1 as u32.private;

view balance_of:
    input r0 as address.public;
    get.or_use balances[r0] 0u64 into r1;
    output r1 as u64.public;

constructor:
    assert.eq edition 0u16;
