    add r8 r9 into r10;
    ternary r4[3u32].is_some r4[3u32].val 9u64 into r11;
    add r10 r11 into r12;
    is.eq r12 14u64 into r13;
    assert.eq r13 true;
    cast r12 into r14 as u64;
    output r12 as u64.private;
