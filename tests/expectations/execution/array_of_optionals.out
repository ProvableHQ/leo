program test.aleo;

struct Optional__DmN5CQ9hzeK:
    is_some as boolean;
    val as u64;

function main:
    cast true 1u64 into r0 as Optional__DmN5CQ9hzeK;
    cast false 0u64 into r1 as Optional__DmN5CQ9hzeK;
    cast true 3u64 into r2 as Optional__DmN5CQ9hzeK;
    cast false 0u64 into r3 as Optional__DmN5CQ9hzeK;
    cast r0 r1 r2 r3 into r4 as [Optional__DmN5CQ9hzeK; 4u32];
    ternary r4[0u32].is_some r4[0u32].val 0u64 into r5;
    ternary r4[1u32].is_some r4[1u32].val 1u64 into r6;
    add r5 r6 into r7;
    ternary r4[2u32].is_some r4[2u32].val 4u64 into r8;
    add r7 r8 into r9;
    ternary r4[3u32].is_some r4[3u32].val 9u64 into r10;
    add r9 r10 into r11;
    is.eq r11 14u64 into r12;
    assert.eq r12 true;
    cast r11 into r13 as u64;
    output r11 as u64.private;
    output r13 as u64.private;

constructor:
    assert.eq edition 0u16;
status: success
output: (14u64, 14u64)
