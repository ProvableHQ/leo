program test.aleo;

struct Optional__DmN5CQ9hzeK:
    is_some as boolean;
    val as u64;

struct Foo:
    x as Optional__DmN5CQ9hzeK;

function main:
    cast true 10u64 into r0 as Optional__DmN5CQ9hzeK;
    cast r0 into r1 as Foo;
    cast false 0u64 into r2 as Optional__DmN5CQ9hzeK;
    cast r2 into r3 as Foo;
    cast true 30u64 into r4 as Optional__DmN5CQ9hzeK;
    cast r4 into r5 as Foo;
    cast false 0u64 into r6 as Optional__DmN5CQ9hzeK;
    cast r6 into r7 as Foo;
    cast r1 r3 r5 r7 into r8 as [Foo; 4u32];
    ternary r8[0u32].x.is_some r8[0u32].x.val 0u64 into r9;
    add 0u64 r9 into r10;
    ternary r8[1u32].x.is_some r8[1u32].x.val 1u64 into r11;
    add r10 r11 into r12;
    ternary r8[2u32].x.is_some r8[2u32].x.val 4u64 into r13;
    add r12 r13 into r14;
    ternary r8[3u32].x.is_some r8[3u32].x.val 9u64 into r15;
    add r14 r15 into r16;
    is.eq r16 50u64 into r17;
    assert.eq r17 true;

constructor:
    assert.eq edition 0u16;
status: success
output: ()
