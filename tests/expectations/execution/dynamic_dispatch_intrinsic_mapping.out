program dyn_mapping.aleo;

mapping m:
    key as u64.public;
    value as u64.public;

function set:
    input r0 as u64.private;
    input r1 as u64.private;
    async set r0 r1 into r2;
    output r2 as dyn_mapping.aleo/set.future;

finalize set:
    input r0 as u64.public;
    input r1 as u64.public;
    set r1 into m[r0];

function check_contains:
    input r0 as field.private;
    input r1 as field.private;
    input r2 as field.private;
    input r3 as u64.private;
    async check_contains r0 r1 r2 r3 into r4;
    output r4 as dyn_mapping.aleo/check_contains.future;

finalize check_contains:
    input r0 as field.public;
    input r1 as field.public;
    input r2 as field.public;
    input r3 as u64.public;
    contains.dynamic r0 r1 r2[r3] into r4;
    assert.eq r4 true;

function check_get:
    input r0 as field.private;
    input r1 as field.private;
    input r2 as field.private;
    input r3 as u64.private;
    async check_get r0 r1 r2 r3 into r4;
    output r4 as dyn_mapping.aleo/check_get.future;

finalize check_get:
    input r0 as field.public;
    input r1 as field.public;
    input r2 as field.public;
    input r3 as u64.public;
    get.dynamic r0 r1 r2[r3] into r4 as u64;
    assert.eq r4 42u64;

function get_use_existing:
    input r0 as field.private;
    input r1 as field.private;
    input r2 as field.private;
    input r3 as u64.private;
    async get_use_existing r0 r1 r2 r3 into r4;
    output r4 as dyn_mapping.aleo/get_use_existing.future;

finalize get_use_existing:
    input r0 as field.public;
    input r1 as field.public;
    input r2 as field.public;
    input r3 as u64.public;
    get.or_use.dynamic r0 r1 r2[r3] 0u64 into r4 as u64;
    assert.eq r4 42u64;

function get_use_missing:
    input r0 as field.private;
    input r1 as field.private;
    input r2 as field.private;
    input r3 as u64.private;
    async get_use_missing r0 r1 r2 r3 into r4;
    output r4 as dyn_mapping.aleo/get_use_missing.future;

finalize get_use_missing:
    input r0 as field.public;
    input r1 as field.public;
    input r2 as field.public;
    input r3 as u64.public;
    get.or_use.dynamic r0 r1 r2[r3] 0u64 into r4 as u64;
    assert.eq r4 0u64;

constructor:
    assert.eq edition 0u16;
verified: true
status: accepted
