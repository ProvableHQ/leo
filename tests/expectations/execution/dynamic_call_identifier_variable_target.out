program var_target.aleo;

function sum:
    input r0 as u32.private;
    input r1 as u32.private;
    add r0 r1 into r2;
    output r2 as u32.private;

constructor:
    assert.eq edition 0u16;
// --- Next Program --- //
import var_target.aleo;
program var_caller.aleo;

function main:
    input r0 as u32.private;
    input r1 as u32.private;
    call.dynamic 'var_target' 'aleo' 'sum' with r0 r1 (as u32.private u32.private) into r2 (as u32.private);
    output r2 as u32.private;

constructor:
    assert.eq edition 0u16;
status: success
output: 8u32
