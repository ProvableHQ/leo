program final_fn_early_unit_return.aleo;

mapping store:
    key as u8.public;
    value as u64.public;

function f:
    input r0 as u64.private;
    async f r0 into r1;
    output r1 as final_fn_early_unit_return.aleo/f.future;

finalize f:
    input r0 as u64.public;
    is.eq r0 0u64 into r1;
    branch.eq r1 false to end_then_0_0;
    branch.eq true true to end_otherwise_0_1;
    position end_then_0_0;
    assert.neq r0 0u64;
    set r0 into store[1u8];
    position end_otherwise_0_1;
    add r0 1u64 into r2;
    set r2 into store[0u8];

constructor:
    assert.eq edition 0u16;
