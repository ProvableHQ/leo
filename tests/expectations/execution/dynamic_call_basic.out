program adder_impl.aleo;

function sum:
    input r0 as u32.private;
    input r1 as u32.private;
    add r0 r1 into r2;
    output r2 as u32.private;

constructor:
    assert.eq edition 0u16;
// --- Next Program --- //
import adder_impl.aleo;
program caller.aleo;

function main:
    input r0 as field.private;
    input r1 as u32.private;
    input r2 as u32.private;
    call.dynamic r0 'aleo' 'sum' with r1 r2 (as u32.private u32.private) into r3 (as u32.private);
    output r3 as u32.private;

constructor:
    assert.eq edition 0u16;
status: success
output: 8u32
