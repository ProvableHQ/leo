program child.aleo;

function entry:
    input r0 as u32.private;
    mul r0 2u32 into r1;
    output r1 as u32.private;

constructor:
    assert.eq edition 0u16;
// --- Next Program --- //
import child.aleo;
program parent.aleo;

function call_once:
    input r0 as u32.private;
    mul r0 2u32 into r1;
    output r1 as u32.private;

function call_twice:
    input r0 as u32.private;
    input r1 as u32.private;
    mul r0 2u32 into r2;
    mul r1 2u32 into r3;
    add r2 r3 into r4;
    output r4 as u32.private;

function call_chained:
    input r0 as u32.private;
    sub r0 1u32 into r1;
    add r1 1u32 into r2;
    add r2 1u32 into r3;
    add r3 1u32 into r4;
    output r4 as u32.private;

constructor:
    assert.eq edition 0u16;
status: success
output: 10u32
status: success
output: 14u32
status: success
output: 8u32
