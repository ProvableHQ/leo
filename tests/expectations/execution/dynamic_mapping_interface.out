program bank.aleo;

mapping balances:
    key as u64.public;
    value as u64.public;

function deposit:
    input r0 as u64.private;
    input r1 as u64.private;
    async deposit r0 r1 into r2;
    output r2 as bank.aleo/deposit.future;

finalize deposit:
    input r0 as u64.public;
    input r1 as u64.public;
    set r1 into balances[r0];

function check_contains:
    input r0 as field.private;
    input r1 as u64.private;
    async check_contains r0 r1 into r2;
    output r2 as bank.aleo/check_contains.future;

finalize check_contains:
    input r0 as field.public;
    input r1 as u64.public;
    contains.dynamic r0 'aleo' 'balances'[r1] into r2;
    assert.eq r2 true;

function check_get:
    input r0 as field.private;
    input r1 as u64.private;
    input r2 as u64.private;
    async check_get r0 r1 r2 into r3;
    output r3 as bank.aleo/check_get.future;

finalize check_get:
    input r0 as field.public;
    input r1 as u64.public;
    input r2 as u64.public;
    get.dynamic r0 'aleo' 'balances'[r1] into r3 as u64;
    assert.eq r3 r2;

function get_or_use_existing:
    input r0 as field.private;
    input r1 as u64.private;
    input r2 as u64.private;
    async get_or_use_existing r0 r1 r2 into r3;
    output r3 as bank.aleo/get_or_use_existing.future;

finalize get_or_use_existing:
    input r0 as field.public;
    input r1 as u64.public;
    input r2 as u64.public;
    get.or_use.dynamic r0 'aleo' 'balances'[r1] r2 into r3 as u64;
    assert.eq r3 42u64;

function get_or_use_missing:
    input r0 as field.private;
    input r1 as u64.private;
    input r2 as u64.private;
    async get_or_use_missing r0 r1 r2 into r3;
    output r3 as bank.aleo/get_or_use_missing.future;

finalize get_or_use_missing:
    input r0 as field.public;
    input r1 as u64.public;
    input r2 as u64.public;
    get.or_use.dynamic r0 'aleo' 'balances'[r1] r2 into r3 as u64;
    assert.eq r3 r2;

constructor:
    assert.eq edition 0u16;
verified: true
status: accepted
