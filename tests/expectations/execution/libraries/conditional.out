program test.aleo;

function classify:
    input r0 as u32.private;
    lt r0 10u32 into r1;
    lt r0 25u32 into r2;
    ternary r2 35u32 110u32 into r3;
    ternary r1 1u32 r3 into r4;
    output r4 as u32.private;

constructor:
    assert.eq edition 0u16;
status: success
output: 1u32
status: success
output: 35u32
status: success
output: 110u32
status: success
output: 110u32
