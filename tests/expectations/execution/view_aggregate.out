program test.aleo;

struct Optional__DmN5CQ9hzeK:
    is_some as boolean;
    val as u64;

mapping balances:
    key as address.public;
    value as u64.public;

mapping entries__:
    key as u32.public;
    value as u64.public;

mapping entries__len__:
    key as boolean.public;
    value as u32.public;

function dummy:
    input r0 as u32.private;
    output r0 as u32.private;

view sum_first_three:
    get.or_use entries__len__[false] 0u32 into r0;
    lt 0u32 r0 into r1;
    get.or_use entries__[0u32] 0u64 into r2;
    cast true r2 into r3 as Optional__DmN5CQ9hzeK;
    ternary r1 r3.is_some false into r4;
    ternary r1 r2 0u64 into r5;
    cast r4 r5 into r6 as Optional__DmN5CQ9hzeK;
    ternary r6.is_some r6.val 0u64 into r7;
    get.or_use entries__len__[false] 0u32 into r8;
    lt 1u32 r8 into r9;
    get.or_use entries__[1u32] 0u64 into r10;
    cast true r10 into r11 as Optional__DmN5CQ9hzeK;
    ternary r9 r11.is_some false into r12;
    ternary r9 r10 0u64 into r13;
    cast r12 r13 into r14 as Optional__DmN5CQ9hzeK;
    ternary r14.is_some r14.val 0u64 into r15;
    add r7 r15 into r16;
    get.or_use entries__len__[false] 0u32 into r17;
    lt 2u32 r17 into r18;
    get.or_use entries__[2u32] 0u64 into r19;
    cast true r19 into r20 as Optional__DmN5CQ9hzeK;
    ternary r18 r20.is_some false into r21;
    ternary r18 r19 0u64 into r22;
    cast r21 r22 into r23 as Optional__DmN5CQ9hzeK;
    ternary r23.is_some r23.val 0u64 into r24;
    add r16 r24 into r25;
    output r25 as u64.public;

view weighted_balance:
    input r0 as address.public;
    input r1 as u32.public;
    get.or_use balances[r0] 0u64 into r2;
    cast r1 into r3 as u64;
    mul r2 r3 into r4;
    output r4 as u64.public;

view capped_balance:
    input r0 as address.public;
    input r1 as u64.public;
    get.or_use balances[r0] 0u64 into r2;
    gt r2 r1 into r3;
    ternary r3 r1 r2 into r4;
    output r4 as u64.public;

constructor:
    assert.eq edition 0u16;
status: success
output: 60u64
status: success
output: 500u64
status: success
output: 50u64
status: success
output: 100u64
