program leaf.aleo;

mapping result__:
    key as boolean.public;
    value as u32.public;

function process:
    input r0 as u32.private;
    mul r0 2u32 into r1;
    async process r1 into r2;
    output r1 as u32.private;
    output r2 as leaf.aleo/process.future;

finalize process:
    input r0 as u32.public;
    set r0 into result__[false];

constructor:
    assert.eq edition 0u16;
// --- Next Program --- //
import leaf.aleo;
program middle.aleo;

function relay:
    input r0 as field.private;
    input r1 as u32.private;
    call.dynamic r0 'aleo' 'process' with r1 (as u32.private) into r2 r3 (as u32.private dynamic.future);
    async relay r3 into r4;
    output r2 as u32.private;
    output r4 as middle.aleo/relay.future;

finalize relay:
    input r0 as dynamic.future;
    await r0;

constructor:
    assert.eq edition 0u16;
// --- Next Program --- //
import leaf.aleo;
import middle.aleo;
program top_caller.aleo;

function main:
    input r0 as field.private;
    input r1 as field.private;
    input r2 as u32.private;
    call.dynamic r0 'aleo' 'relay' with r1 r2 (as field.private u32.private) into r3 r4 (as u32.private dynamic.future);
    async main r4 into r5;
    output r3 as u32.private;
    output r5 as top_caller.aleo/main.future;

finalize main:
    input r0 as dynamic.future;
    await r0;

constructor:
    assert.eq edition 0u16;
verified: true
status: accepted
