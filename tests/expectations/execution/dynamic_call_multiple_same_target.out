program math_impl.aleo;

struct Optional__JzunLORyB8U:
    is_some as boolean;
    val as u32;

mapping total__:
    key as boolean.public;
    value as u32.public;

function compute:
    input r0 as u32.private;
    input r1 as u32.private;
    add r0 r1 into r2;
    async compute r2 into r3;
    output r2 as u32.private;
    output r3 as math_impl.aleo/compute.future;

finalize compute:
    input r0 as u32.public;
    contains total__[false] into r1;
    get.or_use total__[false] 0u32 into r2;
    ternary r1 r2 0u32 into r3;
    ternary r1 r3 0u32 into r4;
    add r4 r0 into r5;
    set r5 into total__[false];

constructor:
    assert.eq edition 0u16;
// --- Next Program --- //
import math_impl.aleo;
program multi_caller.aleo;

function main:
    input r0 as field.private;
    input r1 as u32.private;
    input r2 as u32.private;
    call.dynamic r0 'aleo' 'compute' with r1 r2 (as u32.private u32.private) into r3 r4 (as u32.private dynamic.future);
    call.dynamic r0 'aleo' 'compute' with r1 r3 (as u32.private u32.private) into r5 r6 (as u32.private dynamic.future);
    async main r4 r6 into r7;
    output r5 as u32.private;
    output r7 as multi_caller.aleo/main.future;

finalize main:
    input r0 as dynamic.future;
    input r1 as dynamic.future;
    await r0;
    await r1;

constructor:
    assert.eq edition 0u16;
