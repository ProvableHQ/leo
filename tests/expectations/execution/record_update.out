program test.aleo;

record Token:
    owner as address.private;
    amount as u64.private;
    nonce as u64.private;

function make_and_update:
    input r0 as u64.private;
    cast self.signer 100u64 7u64 into r1 as Token.record;
    cast self.signer r0 7u64 into r2 as Token.record;
    output r1 as Token.record;
    output r2 as Token.record;

constructor:
    assert.eq edition 0u16;
status: success
