program test.aleo;

function main:
    cast 1u32 into r0 as [u32; 1u32];
    cast 2u32 2u32 into r1 as [u32; 2u32];
    add r0[0u32] r1[1u32] into r2;
    cast 3u32 3u32 3u32 into r3 as [u32; 3u32];
    add r2 r3[2u32] into r4;
    cast 4u32 4u32 4u32 4u32 into r5 as [u32; 4u32];
    add r4 r5[3u32] into r6;
    cast 5u32 5u32 5u32 5u32 5u32 into r7 as [u32; 5u32];
    add r6 r7[4u32] into r8;
    cast 6u32 6u32 6u32 6u32 6u32 6u32 into r9 as [u32; 6u32];
    add r8 r9[5u32] into r10;
    cast 7u32 7u32 7u32 7u32 7u32 7u32 7u32 into r11 as [u32; 7u32];
    add r10 r11[6u32] into r12;
    cast 8u32 8u32 8u32 8u32 8u32 8u32 8u32 8u32 into r13 as [u32; 8u32];
    add r12 r13[7u32] into r14;
    cast 9u32 9u32 9u32 9u32 9u32 9u32 9u32 9u32 9u32 into r15 as [u32; 9u32];
    add r14 r15[8u32] into r16;
    output r16 as u32.private;

constructor:
    assert.eq edition 0u16;
status: success
output: 45u32
