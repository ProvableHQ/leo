program child.aleo;

function get_top:
    output 5u32 as u32.private;

constructor:
    assert.eq edition 0u16;
// --- Next Program --- //
import child.aleo;
program parent.aleo;

function use_deep:
    output 7u32 as u32.private;

function scale:
    input r0 as u32.private;
    mul r0 7u32 into r1;
    output r1 as u32.private;

function combined_consts:
    output 32u32 as u32.private;

constructor:
    assert.eq edition 0u16;
status: success
output: 7u32
status: success
output: 21u32
status: success
output: 32u32
