program child.aleo;

function identity:
    input r0 as u32.private;
    output r0 as u32.private;

constructor:
    assert.eq edition 0u16;
// --- Next Program --- //
import child.aleo;
program parent.aleo;

function compute:
    input r0 as u32.private;
    mul r0 3u32 into r1;
    mul r0 5u32 into r2;
    add r1 r2 into r3;
    output r3 as u32.private;

constructor:
    assert.eq edition 0u16;
status: success
output: 80u32
