program final_fn_return_conditional.aleo;

mapping store:
    key as u8.public;
    value as u64.public;

function f:
    input r0 as u64.private;
    async f r0 into r1;
    output r1 as final_fn_return_conditional.aleo/f.future;

finalize f:
    input r0 as u64.public;
    gt r0 1000u64 into r1;
    branch.eq r1 false to end_then_0_0;
    set 1000u64 into store[0u8];
    branch.eq true true to end_otherwise_0_1;
    position end_then_0_0;
    set r0 into store[0u8];
    lte r0 1000u64 into r2;
    assert.eq r2 true;
    position end_otherwise_0_1;

constructor:
    assert.eq edition 0u16;
