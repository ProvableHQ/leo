program final_fn_split_continuation.aleo;

mapping store:
    key as u8.public;
    value as u64.public;

function f:
    input r0 as u64.private;
    async f r0 into r1;
    output r1 as final_fn_split_continuation.aleo/f.future;

finalize f:
    input r0 as u64.public;
    gt r0 1000u64 into r1;
    branch.eq r1 false to end_then_0_0;
    add r0 7u64 into r2;
    set 1000u64 into store[0u8];
    set r2 into store[1u8];
    branch.eq true true to end_otherwise_0_1;
    position end_then_0_0;
    add r0 7u64 into r3;
    set r0 into store[0u8];
    set r3 into store[1u8];
    position end_otherwise_0_1;

function g:
    input r0 as u64.private;
    async g r0 into r1;
    output r1 as final_fn_split_continuation.aleo/g.future;

finalize g:
    input r0 as u64.public;
    gt r0 1000u64 into r1;
    branch.eq r1 false to end_then_0_0;
    set 1000u64 into store[2u8];
    branch.eq true true to end_otherwise_0_1;
    position end_then_0_0;
    set r0 into store[2u8];
    position end_otherwise_0_1;
    set r0 into store[3u8];

constructor:
    assert.eq edition 0u16;
