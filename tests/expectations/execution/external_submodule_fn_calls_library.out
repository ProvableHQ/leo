program child.aleo;

function entry:
    input r0 as u32.private;
    output r0 as u32.private;

constructor:
    assert.eq edition 0u16;
// --- Next Program --- //
import child.aleo;
program parent.aleo;

function compute:
    input r0 as u32.private;
    add r0 1u32 into r1;
    mul r1 2u32 into r2;
    add r2 r1 into r3;
    output r3 as u32.private;

constructor:
    assert.eq edition 0u16;
status: success
output: 18u32
