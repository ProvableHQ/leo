    output r0 as rand_dce_probe.aleo/with_used.future;

finalize with_used:
    rand.chacha into r0 as u8;
    rand.chacha into r1 as u8;
    set r0 into values[1u8];
    set r1 into values[0u8];

constructor:
    assert.eq edition 0u16;
