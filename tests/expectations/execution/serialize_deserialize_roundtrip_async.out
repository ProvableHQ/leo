program test.aleo;

function test_async_u32_rt:
    input r0 as u32.private;
    async test_async_u32_rt self.caller r0 into r1;
    output r1 as test.aleo/test_async_u32_rt.future;

finalize test_async_u32_rt:
    input r0 as address.public;
    input r1 as u32.public;
    serialize.bits r1 (u32) into r2 ([boolean; 58u32]);
    deserialize.bits r2 ([boolean; 58u32]) into r3 (u32);
    is.eq r1 r3 into r4;
    serialize.bits.raw r1 (u32) into r5 ([boolean; 32u32]);
    deserialize.bits.raw r5 ([boolean; 32u32]) into r6 (u32);
    is.eq r1 r6 into r7;
    and r4 r7 into r8;
    assert.eq r8 true;

function test_async_field_rt:
    input r0 as field.private;
    async test_async_field_rt self.caller r0 into r1;
    output r1 as test.aleo/test_async_field_rt.future;

finalize test_async_field_rt:
    input r0 as address.public;
    input r1 as field.public;
    serialize.bits r1 (field) into r2 ([boolean; 279u32]);
    deserialize.bits r2 ([boolean; 279u32]) into r3 (field);
    is.eq r1 r3 into r4;
    serialize.bits.raw r1 (field) into r5 ([boolean; 253u32]);
    deserialize.bits.raw r5 ([boolean; 253u32]) into r6 (field);
    is.eq r1 r6 into r7;
    and r4 r7 into r8;
    assert.eq r8 true;

function test_async_array_rt:
    input r0 as [u8; 2u32].private;
    async test_async_array_rt self.caller r0 into r1;
    output r1 as test.aleo/test_async_array_rt.future;

finalize test_async_array_rt:
    input r0 as address.public;
    input r1 as [u8; 2u32].public;
    serialize.bits r1 ([u8; 2u32]) into r2 ([boolean; 134u32]);
    deserialize.bits r2 ([boolean; 134u32]) into r3 ([u8; 2u32]);
    is.eq r1[0u32] r3[0u32] into r4;
    is.eq r1[1u32] r3[1u32] into r5;
    and r4 r5 into r6;
    serialize.bits.raw r1 ([u8; 2u32]) into r7 ([boolean; 16u32]);
    deserialize.bits.raw r7 ([boolean; 16u32]) into r8 ([u8; 2u32]);
    is.eq r1[0u32] r8[0u32] into r9;
    is.eq r1[1u32] r8[1u32] into r10;
    and r9 r10 into r11;
    and r6 r11 into r12;
    assert.eq r12 true;

constructor:
    assert.eq edition 0u16;
