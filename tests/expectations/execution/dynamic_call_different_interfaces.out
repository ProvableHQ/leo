program adder_target.aleo;

function sum:
    input r0 as u32.private;
    input r1 as u32.private;
    add r0 r1 into r2;
    output r2 as u32.private;

constructor:
    assert.eq edition 0u16;
// --- Next Program --- //
program multiplier_target.aleo;

function product:
    input r0 as u32.private;
    input r1 as u32.private;
    mul r0 r1 into r2;
    output r2 as u32.private;

constructor:
    assert.eq edition 0u16;
// --- Next Program --- //
import adder_target.aleo;
import multiplier_target.aleo;
program combo_caller.aleo;

function main:
    input r0 as field.private;
    input r1 as field.private;
    input r2 as u32.private;
    input r3 as u32.private;
    call.dynamic r0 'aleo' 'sum' with r2 r3 (as u32.private u32.private) into r4 (as u32.private);
    call.dynamic r1 'aleo' 'product' with r2 r3 (as u32.private u32.private) into r5 (as u32.private);
    add r4 r5 into r6;
    output r6 as u32.private;

constructor:
    assert.eq edition 0u16;
status: success
output: 23u32
